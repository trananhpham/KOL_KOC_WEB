@model KOL_KOC_TAAA.ViewModels.PublicKolProfileViewModel
@{
    ViewData["Title"] = $"Hồ sơ KOL {Model.FullName} - {Model.InfluencerType} Influencer tại {Model.LocationCity}";
    ViewData["MetaDescription"] = $"Xem hồ sơ chi tiết của KOL {Model.FullName}. Chuyên gia {Model.InfluencerType} tại {Model.LocationCity}. Xem bảng giá dịch vụ và các sản phẩm đã thực hiện.";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="Search" class="text-decoration-none">KOLs</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.FullName</li>
    </ol>
</nav>

<div class="row g-4">
    <!-- Left column: Profile info -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 sticky-top" style="top: 100px;">
            <div class="card-body text-center p-4">
                <div class="position-relative d-inline-block mb-4">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.FullName)&size=200&background=random" class="rounded-circle shadow-sm" alt="@Model.FullName" style="width: 150px; height: 150px; object-fit: cover; border: 4px solid #fff;">
                    @if (Model.IsVerified)
                    {
                        <div class="position-absolute bottom-0 end-0 bg-white rounded-circle p-1 shadow-sm">
                            <i class="bi bi-patch-check-fill text-primary fs-3"></i>
                        </div>
                    }
                </div>
                
                <h1 class="h3 fw-bold mb-1">@Model.FullName</h1>
                <p class="text-primary fw-medium mb-3">@Model.InfluencerType Influencer</p>
                
                <div class="d-flex justify-content-center gap-2 mb-4">
                    <span class="badge bg-warning text-dark px-3 py-2">⭐ @Model.RatingAvg</span>
                    <span class="badge bg-light text-muted px-3 py-2 border">@Model.RatingCount đánh giá</span>
                </div>

                <div class="d-flex align-items-center justify-content-center text-muted small mb-4">
                    <i class="bi bi-geo-alt-fill me-2 text-danger"></i> @Model.LocationCity, @Model.LocationCountry
                </div>
                
                <hr class="my-4 opacity-10">
                
                <div class="text-start mb-4">
                    <h6 class="fw-bold text-uppercase small text-muted mb-3">Giới thiệu</h6>
                    <p class="text-secondary small line-height-lg">
                        @(string.IsNullOrWhiteSpace(Model.Bio) ? "KOL này hiện chưa cập nhật tiểu sử chi tiết." : Model.Bio)
                    </p>
                </div>

                <div class="text-start">
                    <h6 class="fw-bold text-uppercase small text-muted mb-3">Mạng xã hội</h6>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var social in Model.SocialAccounts)
                        {
                            <a href="@social.ProfileUrl" target="_blank" class="btn btn-outline-light text-dark btn-sm border shadow-xs d-flex align-items-center gap-2">
                                <i class="bi bi-link-45deg"></i>
                                <span class="fw-semibold">@social.Platform</span>
                                <span class="text-muted small">@(social.Followers?.ToString("N0") ?? "0")</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right column: Rate Cards & Portfolio -->
    <div class="col-lg-8">
        <!-- Rate Cards -->
        <div class="card border-0 mb-4 h-auto">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <h4 class="fw-bold mb-0">Bảng giá dịch vụ</h4>
                <p class="text-muted small">Lựa chọn gói dịch vụ phù hợp với ngân sách của bạn</p>
            </div>
            <div class="card-body p-4 pt-2">
                @if (!Model.RateCards.Any())
                {
                    <div class="text-center py-4 bg-light rounded-3">
                        <i class="bi bi-cash-stack fs-1 text-muted opacity-50 mb-2"></i>
                        <p class="text-muted">KOL này chưa công khai bảng giá chi tiết.</p>
                        <button class="btn btn-outline-primary btn-sm rounded-pill">Liên hệ báo giá</button>
                    </div>
                }
                else
                {
                    @foreach (var rc in Model.RateCards)
                    {
                        <div class="mb-4 last-child-mb-0">
                            <h5 class="fw-bold fs-6 border-start border-4 border-primary ps-2 mb-3">@rc.Title</h5>
                            <div class="row g-3">
                                @foreach (var item in rc.RateCardItems)
                                {
                                    <div class="col-md-6">
                                        <div class="p-3 border rounded-3 bg-light-subtle h-100">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <div class="fw-bold text-dark">@item.ServiceType</div>
                                                <div class="text-primary fw-bold">@item.UnitPrice.ToString("N0") <small>@rc.Currency</small></div>
                                            </div>
                                            <p class="text-muted mb-3 small">@item.Description</p>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="text-muted small"><i class="bi bi-clock me-1"></i>@(item.DurationMinutes ?? 0)m</span>
                                                <a asp-controller="Booking" asp-action="Create" asp-route-kolId="@Model.UserId" class="btn btn-primary btn-sm rounded-pill">Chọn gói</a>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
        
        <!-- Portfolio -->
        <div class="card border-0">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <h4 class="fw-bold mb-0">Portfolio Highlights</h4>
                <p class="text-muted small">Sản phẩm tiêu biểu đã thực hiện</p>
            </div>
            <div class="card-body p-4 pt-2">
                @if (!Model.Portfolios.Any())
                {
                    <div class="row g-3">
                        @for (int i = 1; i <= 3; i++)
                        {
                            <div class="col-md-4">
                                <div class="ratio ratio-1x1 bg-light rounded-3 d-flex align-items-center justify-content-center border border-dashed">
                                    <i class="bi bi-image text-muted fs-1 opacity-25"></i>
                                </div>
                            </div>
                        }
                        <div class="col-12 text-center mt-3">
                            <p class="text-muted small italic">Chưa có sản phẩm demo được tải lên.</p>
                        </div>
                    </div>
                }
                else {
                    <div class="row g-3">
                         @foreach(var p in Model.Portfolios) {
                             <div class="col-md-4">
                                <div class="card h-100 border p-1 shadow-xs">
                                    <img src="https://picsum.photos/seed/@p.Id/400/400" class="img-fluid rounded-2" alt="Portfolio Image">
                                    <div class="card-body p-2">
                                        <h6 class="small fw-bold mb-1">@p.Title</h6>
                                        <a href="@p.MediaUrl" target="_blank" class="very-small text-primary text-decoration-none">Link chi tiết <i class="bi bi-external-link"></i></a>
                                    </div>
                                </div>
                             </div>
                         }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
