@using KOL_KOC_TAAA.ViewModels
@model IEnumerable<PublicKolProfileViewModel>
@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_LayoutLuxury";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<!-- 1. HERO BENTO SECTION -->
<!-- Dùng chung Hero cho cả lúc đang nhập và chưa đăng nhập, vì nền tảng là dạng khám phá cao cấp -->
@await Html.PartialAsync("Partials/_HeroBento")

<!-- 3. RECOMMENDED SECTION (REFINED BENTO RHYTHM) -->
@await Html.PartialAsync("Partials/_RecommendedSection", Model)

<!-- 4. TRUST & BRANDING (Moved below for better rhythm) -->
@if (!isAuthenticated)
{
    @await Html.PartialAsync("Partials/_TrustSection")
}

<!-- Additional space for discovery -->
<div class="container pb-5">
    <hr class="opacity-0 my-5">
</div>
