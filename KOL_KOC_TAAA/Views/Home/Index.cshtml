@using System.Linq
@model IEnumerable<KOL_KOC_TAAA.ViewModels.PublicKolProfileViewModel>
@{
    ViewData["Title"] = "Trang chủ - Tìm kiếm KOL/KOC Chuyên nghiệp";
    ViewData["MetaDescription"] = "Khám phá danh sách KOL, KOC hàng đầu tại Việt Nam. Kết nối thương hiệu với Influencer phù hợp thông qua nền tảng công nghệ hiện đại.";
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
}

@if (!isAuthenticated)
{
    @* --- Giao diện LANDING PAGE (Dành cho khách vãng lai/chưa đăng nhập) --- *@
    
    <!-- Hero Section -->
    <div class="hero-premium text-center position-relative overflow-hidden" style="background: var(--mesh-bg); padding: 120px 0;">
        <div class="container position-relative z-2">
            <div class="animate-float">
                <span class="badge badge-premium bg-primary-light text-primary mb-3">Nền tảng Kết nối Influencer #1</span>
                <h1 class="display-2 fw-bold mb-3" style="letter-spacing: -2px;">Đưa Thương Hiệu Lên<br><span class="text-gradient">Tầm Cao Mới</span></h1>
                <p class="lead text-muted mb-5 mx-auto" style="max-width: 700px; font-size: 1.25rem;">Kết nối trực tiếp với hơn 5.000+ KOL/KOC chuyên nghiệp. Tối ưu chiến dịch Marketing với dữ liệu thực tế và hỗ trợ từ AI.</p>
                <div class="d-flex justify-content-center gap-3 mb-5">
                    <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-lg btn-pill px-5 py-3 shadow-premium shimmer">Bắt đầu ngay</a>
                    <a href="#how-it-works" class="btn btn-outline-primary btn-lg btn-pill px-5 py-3">Tìm hiểu thêm</a>
                </div>
            </div>
            
            <!-- Hero Search Preview (Dạng mô phỏng) -->
            <div class="glass-card p-3 shadow-premium mx-auto opacity-75" style="max-width: 800px; border-radius: 2rem; transform: scale(0.95);">
                <div class="row g-2 p-1 align-items-center">
                    <div class="col-8 text-start ps-4">
                        <span class="text-muted"><i class="bi bi-search me-2"></i>Tìm kiếm Idol theo lĩnh vực...</span>
                    </div>
                    <div class="col-4">
                        <div class="btn btn-primary w-100 rounded-pill py-2 disabled">Khám phá</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Benefits Section -->
    <section class="landing-section bg-white">
        <div class="container">
            <div class="text-center mb-5 pb-3">
                <h6 class="text-primary fw-bold text-uppercase letter-spacing-1 mb-2">Giá trị mang lại</h6>
                <h2 class="section-title">Tại sao chọn KOL Market?</h2>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto"><i class="bi bi-shield-check"></i></div>
                        <h4>Idol Đã Xác Thực</h4>
                        <p class="text-muted">100% profile được kiểm duyệt thủ công, đảm bảo số liệu thật và uy tín tuyệt đối.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto"><i class="bi bi-lightning-charge"></i></div>
                        <h4>Thanh Toán Nhanh</h4>
                        <p class="text-muted">Tích hợp ví MoMo và quy trình ký hợp đồng điện tử bảo mật, giải ngân nhanh chóng.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto"><i class="bi bi-robot"></i></div>
                        <h4>Hỗ Trợ AI 24/7</h4>
                        <p class="text-muted">Trợ lý AI thông minh tư vấn chiến dịch và gợi ý KOL phù hợp với ngân sách của bạn.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- How it works -->
    <section id="how-it-works" class="landing-section bg-light">
        <div class="container">
            <div class="text-center mb-5 pb-3">
                <h2 class="section-title">Quy trình đơn giản</h2>
            </div>
            <div class="row g-4 justify-content-center">
                <div class="col-md-3">
                    <div class="step-item">
                        <div class="step-number">1</div>
                        <h5>Tìm kiếm</h5>
                        <p class="small text-muted">Lọc KOL theo hạng, giá và lĩnh vực.</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="step-item">
                        <div class="step-number">2</div>
                        <h5>Trao đổi</h5>
                        <p class="small text-muted">Chat trực tiếp và nhận tư vấn từ AI.</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="step-item">
                        <div class="step-number">3</div>
                        <h5>Ký kết</h5>
                        <p class="small text-muted">Thanh toán đặt cọc và bắt đầu việc.</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="step-item">
                        <div class="step-number">4</div>
                        <h5>Hoàn tất</h5>
                        <p class="small text-muted">Nghiệm thu và giải ngân an toàn.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="landing-section bg-white border-top">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4 stat-item">
                    <span class="stat-value">5,000+</span>
                    <span class="stat-label">Influencers</span>
                </div>
                <div class="col-md-4 stat-item">
                    <span class="stat-value">12,000+</span>
                    <span class="stat-label">Chiến dịch đã chạy</span>
                </div>
                <div class="col-md-4 stat-item">
                    <span class="stat-value">98%</span>
                    <span class="stat-label">Khách hàng hài lòng</span>
                </div>
            </div>
        </div>
    </section>
}
else
{
    @* --- Giao diện DASHBOARD (Dành cho người dùng ĐÃ ĐĂNG NHẬP) --- *@
    
    <div class="hero-premium text-center position-relative overflow-hidden" style="background: var(--mesh-bg); padding: 80px 0;">
        <div class="container position-relative z-2">
            <div class="animate-float">
                <h1 class="display-4 fw-bold mb-3">Chào mừng quay lại,<br><span class="text-gradient">@Context.Session.GetString("UserName")</span></h1>
                <p class="text-muted mb-5">Hôm nay bạn muốn kết nối với ai?</p>
            </div>
            
            <div class="glass-card p-3 shadow-premium mx-auto" style="max-width: 850px; border-radius: 2rem;">
                <form asp-action="Search" method="get" class="row g-2 p-1">
                    <div class="col-md-5">
                        <div class="input-group input-group-lg border-0 bg-white rounded-pill overflow-hidden px-2">
                            <span class="input-group-text bg-white border-0"><i class="bi bi-search text-primary"></i></span>
                            <input type="text" name="query" class="form-control border-0 px-0" placeholder="Idol, lĩnh vực, từ khóa...">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select name="type" class="form-select form-select-lg border-0 bg-white rounded-pill fw-medium">
                            <option value="">Hạng Idol</option>
                            <option value="Nano">Nano (1k - 10k)</option>
                            <option value="Micro">Micro (10k - 50k)</option>
                            <option value="Macro">Macro (50k - 500k)</option>
                            <option value="Mega">Mega (>500k)</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3 shimmer">Tìm kiếm ngay</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@* --- Phần Listing KOL (Luôn hiển thị nhưng có tiêu đề khác nhau) --- *@
<div class="container section-results py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            @if (!isAuthenticated)
            {
                <h2 class="fw-bold mb-1">Gợi ý KOL nổi bật</h2>
                <p class="text-muted small">Khám phá tiềm năng từ mạng lưới của chúng tôi</p>
            }
            else
            {
                <h2 class="fw-bold mb-1">Dành riêng cho bạn <i class="bi bi-stars text-warning"></i></h2>
                <p class="text-muted small">Cập nhật danh sách Idol mới nhất hôm nay</p>
            }
        </div>
        <a asp-action="Search" class="btn btn-outline-primary btn-pill fw-bold">Xem tất cả</a>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" style="width: 120px; opacity: 0.3;" class="mb-3">
                <p class="text-muted">Đang cập nhật danh sách Idol mới...</p>
            </div>
        }
        @foreach (var kol in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-lift">
                    <div class="position-relative">
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(kol.FullName)&size=400&background=random" class="card-img-top" alt="@kol.FullName" style="height: 240px; object-fit: cover;">
                        <span class="position-absolute top-0 end-0 m-3 badge badge-premium bg-white shadow-sm text-primary">
                            @kol.InfluencerType
                        </span>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="fw-bold mb-0">@kol.FullName</h5>
                            @if (kol.IsVerified)
                            {
                                <i class="bi bi-patch-check-fill text-primary" title="Đã xác thực"></i>
                            }
                        </div>
                        
                        <p class="text-muted small mb-3"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@kol.LocationCity</p>
                        
                        <div class="d-flex align-items-center mb-1">
                            <span class="text-warning fw-bold me-2">⭐ @kol.RatingAvg</span>
                            <span class="text-muted small">(@kol.RatingCount đánh giá)</span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                            <div>
                                <span class="text-muted very-small d-block">Ngân sách từ</span>
                                <span class="fw-bold text-primary fs-4">@(kol.MinBudget?.ToString("N0") ?? "--")</span>
                                <span class="small text-muted">VND</span>
                            </div>
                            <a asp-action="KolDetail" asp-route-id="@kol.UserId" class="btn btn-primary btn-sm rounded-pill px-3 py-2">
                                Chi tiết <i class="bi bi-chevron-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!isAuthenticated)
    {
        <!-- Bottom CTA -->
        <div class="cta-banner">
            <h2 class="display-5 fw-bold mb-4">Sẵn sàng bùng nổ chiến dịch?</h2>
            <p class="lead text-muted mb-5 mx-auto" style="max-width: 600px;">Đăng ký tài khoản ngay hôm nay để nhận tư vấn miễn phí từ AI và kết nối với những KOL hàng đầu.</p>
            <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-lg btn-pill px-5 py-3 shadow-premium shimmer">Đăng ký tài khoản ngay</a>
        </div>
    }
</div>


