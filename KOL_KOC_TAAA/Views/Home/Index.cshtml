@model IEnumerable<KOL_KOC_TAAA.ViewModels.PublicKolProfileViewModel>
@{
    ViewData["Title"] = "Trang chủ - Tìm kiếm KOL/KOC Chuyên nghiệp";
    ViewData["MetaDescription"] = "Khám phá danh sách KOL, KOC hàng đầu tại Việt Nam. Tìm kiếm theo hạng Nano, Micro, Macro và Mega để tối ưu hóa chiến dịch marketing của bạn.";
}

<div class="hero-premium text-center">
    <div class="container">
        <h1 class="display-3 fw-bold mb-3">Tỏa sáng chiến dịch của bạn với <span class="text-gradient">KOL hàng đầu</span></h1>
        <p class="lead text-muted mb-5 mx-auto" style="max-width: 700px;">Hàng ngàn Influencer chất lượng đã được xác thực, sẵn sàng đồng hành cùng thương hiệu của bạn vươn xa.</p>
        
        <div class="card p-2 shadow-lg border-0 mx-auto" style="max-width: 900px; border-radius: 1.5rem;">
            <form asp-action="Search" method="get" class="row g-2 p-1">
                <div class="col-md-5">
                    <div class="input-group input-group-lg border-0">
                        <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="query" class="form-control border-0 bg-white" placeholder="Tìm tên KOL, kỹ năng, lĩnh vực...">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="type" class="form-select form-select-lg border-0 bg-white">
                        <option value="">Tất cả hạng</option>
                        <option value="Nano">Nano (1k - 10k)</option>
                        <option value="Micro">Micro (10k - 50k)</option>
                        <option value="Macro">Macro (50k - 500k)</option>
                        <option value="Mega">Mega (>500k)</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3">Khám phá ngay</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container section-results">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1">KOL Nổi Bật</h2>
            <p class="text-muted small mb-0">Những gương mặt tiêu biểu nhất tuần này</p>
        </div>
        <a asp-action="Search" class="btn btn-link text-decoration-none fw-semibold">Xem tất cả <i class="bi bi-arrow-right"></i></a>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted py-5">
                <p>Chưa có KOL nào để hiển thị.</p>
            </div>
        }
        @foreach (var kol in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(kol.FullName)&size=400&background=random" class="card-img-top" alt="@kol.FullName" style="height: 200px; object-fit: cover; opacity: 0.8;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">@kol.FullName</h5>
                            <span class="badge badge-premium bg-primary">@kol.InfluencerType</span>
                        </div>
                        
                        <p class="text-muted small mb-3"><i class="bi bi-geo-alt me-1"></i>@kol.LocationCity</p>
                        
                        <div class="d-flex align-items-center mb-3">
                            <span class="text-warning fw-bold me-1">⭐ @kol.RatingAvg</span>
                            <span class="text-muted small">(@kol.RatingCount đánh giá)</span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-muted small d-block">Giá từ</span>
                                <span class="fw-bold text-primary fs-5">@(kol.MinBudget?.ToString("N0") ?? "--")</span>
                                <span class="small text-muted">VND</span>
                            </div>
                            @if (kol.IsVerified)
                            {
                                <i class="bi bi-patch-check-fill text-primary" title="Đã xác thực" style="font-size: 1.2rem;"></i>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 p-3 pt-0">
                        <a asp-action="KolDetail" asp-route-id="@kol.UserId" class="btn btn-outline-primary btn-pill w-100">Chi tiết hồ sơ</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
