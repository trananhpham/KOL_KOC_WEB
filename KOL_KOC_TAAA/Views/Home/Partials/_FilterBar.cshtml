<div class="lux-filter-bar position-sticky py-3 mb-5" style="top: 76px; z-index: 1020; background: rgba(253, 252, 251, 0.9); backdrop-filter: blur(20px); border-bottom: 1px solid var(--lux-border-light);">
    <div class="container d-flex align-items-center justify-content-between">
        
        <!-- Filter Chips (Scrollable on mobile, flex on desktop) -->
        <div class="d-flex align-items-center gap-2 overflow-auto hide-scrollbar flex-grow-1 pe-4" style="white-space: nowrap;">
            <div class="fw-medium text-dark pe-2 me-2 border-end border-2" style="font-size: 0.95rem;">Lọc nhanh:</div>
            
            <button class="btn btn-sm rounded-pill fw-medium lux-surface lux-surface-hover px-3 py-2 active" style="background: var(--lux-primary-indigo); color: white; border: none;">
                Tất cả
            </button>
            <button class="btn btn-sm rounded-pill fw-medium px-3 py-2" style="background: transparent; border: 1px solid var(--lux-border-light); color: var(--lux-text-muted); transition: all 0.3s;">
                <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.8rem;"></i> Top Trending
            </button>
            <button class="btn btn-sm rounded-pill fw-medium px-3 py-2" style="background: transparent; border: 1px solid var(--lux-border-light); color: var(--lux-text-muted); transition: all 0.3s;">
                <i class="bi bi-tiktok me-1" style="color: #000;"></i> TikToker
            </button>
            <button class="btn btn-sm rounded-pill fw-medium px-3 py-2" style="background: transparent; border: 1px solid var(--lux-border-light); color: var(--lux-text-muted); transition: all 0.3s;">
                <i class="bi bi-instagram me-1" style="color: #E1306C;"></i> Instagram
            </button>
            <button class="btn btn-sm rounded-pill fw-medium px-3 py-2" style="background: transparent; border: 1px solid var(--lux-border-light); color: var(--lux-text-muted); transition: all 0.3s;">
                Fashion & Beauty
            </button>
            <button class="btn btn-sm rounded-pill fw-medium px-3 py-2" style="background: transparent; border: 1px solid var(--lux-border-light); color: var(--lux-text-muted); transition: all 0.3s;">
                F&B / Ẩm thực
            </button>
            <button class="btn btn-sm rounded-pill fw-medium px-3 py-2" style="background: transparent; border: 1px solid var(--lux-border-light); color: var(--lux-text-muted); transition: all 0.3s;">
                Nano & Micro
            </button>
        </div>

        <!-- Advanced Filter & Sort -->
        <div class="d-flex align-items-center gap-3 ms-auto flex-shrink-0">
            <div class="dropdown">
                <button class="btn btn-sm d-flex align-items-center gap-2 fw-medium px-3 py-2" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="background: transparent; border: none; color: var(--lux-text-charcoal);">
                    Sắp xếp theo <i class="bi bi-chevron-down small text-muted"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" style="border-radius: 12px; border: 1px solid var(--lux-border-light) !important;">
                    <li><a class="dropdown-item py-2 small fw-medium text-dark" href="#">Đề xuất tốt nhất (AI)</a></li>
                    <li><a class="dropdown-item py-2 small" href="#">Số Followers cao nhất</a></li>
                    <li><a class="dropdown-item py-2 small" href="#">Engagement rate cao nhất</a></li>
                    <li><a class="dropdown-item py-2 small" href="#">Mới nổi (Rising)</a></li>
                </ul>
            </div>

            <button class="btn btn-sm d-flex align-items-center gap-2 rounded-pill fw-medium px-3 py-2 shadow-sm" style="background: #fff; border: 1px solid var(--lux-border-light); color: var(--lux-text-charcoal); transition: all 0.3s;">
                <i class="bi bi-sliders text-muted"></i> Bộ lọc sâu
            </button>
        </div>
    </div>
    <style>
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .lux-filter-bar button:not(.active):hover { background: #fff !important; color: var(--lux-text-charcoal) !important; border-color: rgba(0,0,0,0.15) !important; }
    </style>
</div>
