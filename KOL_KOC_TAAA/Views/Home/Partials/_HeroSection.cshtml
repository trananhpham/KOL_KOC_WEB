@model KOL_KOC_TAAA.ViewModels.HomeIndexViewModel

<section class="lux-hero pt-5 pb-4 overflow-hidden">
    <div class="container py-5 position-relative">
        <div class="row align-items-center">
            <div class="col-lg-8 mx-auto text-center" data-reveal="fade-up">
                <!-- 1. BADGE -->
                <div class="d-inline-flex align-items-center gap-2 px-3 py-1 rounded-pill mb-4" 
                     style="background: rgba(var(--lux-accent-gold-rgb), 0.1); border: 1px solid var(--lux-accent-gold);">
                    <i class="bi bi-stars" style="color: var(--lux-accent-gold);"></i>
                    <span class="fw-bold" style="font-size: 0.75rem; letter-spacing: 1px; color: var(--lux-accent-gold);">TOP #1 KOL MARKETPLACE VN</span>
                </div>

                <!-- 2. HEADLINE -->
                <h1 class="display-3 fw-bold lux-h1 mb-4" style="line-height: 1.1; letter-spacing: -2px;">
                    Kết nối tài năng. <br>
                    <span class="text-gradient-gold">Định hình thương hiệu.</span>
                </h1>

                <!-- 3. SUBHEADLINE -->
                <p class="lead text-muted mb-5 mx-auto" style="max-width: 600px; font-weight: 400;">
                    Nền tảng kết nối KOL/KOC chuyên nghiệp, minh bạch và hiệu quả nhất. 
                    Mang tầm ảnh hưởng thật đến với doanh nghiệp của bạn qua các chiến dịch đột phá.
                </p>

                <!-- 4. SEARCH BOX BENTO -->
                <div class="lux-search-box-wrap mx-auto mb-4" style="max-width: 750px;">
                    <form action="@Url.Action("Search", "Home")" method="get" class="lux-search-box p-2 d-flex flex-column flex-md-row gap-2">
                        <div class="flex-grow-1 position-relative">
                            <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                            <input type="text" name="query" class="form-control border-0 ps-5 py-3 shadow-none bg-transparent" 
                                   placeholder="Bạn đang tìm kiếm KOL trong lĩnh vực nào?">
                        </div>
                        <div class="d-flex gap-2">
                            <select name="category" class="form-select border-0 py-3 shadow-none bg-light rounded-3" style="width: auto; min-width: 140px;">
                                <option value="">Lĩnh vực</option>
                                <option value="BeautyFashion">Làm đẹp</option>
                                <option value="Tech">Công nghệ</option>
                                <option value="FoodBeverage">Ẩm thực</option>
                                <option value="Travel">Du lịch</option>
                            </select>
                            <button type="submit" class="lux-btn-primary px-4 py-3">TÌM KIẾM</button>
                        </div>
                    </form>
                </div>

                <!-- 5. QUICK CHIPS -->
                <div class="d-flex flex-wrap justify-content-center gap-2 mb-5">
                    <span class="text-muted small me-2 mt-1">Xu hướng:</span>
                    <a href="/Home/Search?category=BeautyFashion" class="lux-chip">#Beauty</a>
                    <a href="/Home/Search?category=Tech" class="lux-chip">#TechReview</a>
                    <a href="/Home/Search?category=FoodBeverage" class="lux-chip">#Mukbang</a>
                    <a href="/Home/Search?category=Travel" class="lux-chip">#Vlogger</a>
                    <a href="/Home/Search?category=Gaming" class="lux-chip">#Gaming</a>
                </div>

                <!-- 6. MINI STATS -->
                <div class="row justify-content-center g-4 mt-2">
                    <div class="col-6 col-md-3">
                        <div class="small fw-bold">@Model.Stats.ActiveKols+</div>
                        <div class="small text-muted opacity-75">Tài năng active</div>
                    </div>
                    <div class="col-6 col-md-3 border-start">
                        <div class="small fw-bold">@Model.Stats.CompletedCampaigns+</div>
                        <div class="small text-muted opacity-75">Chiến dịch xong</div>
                    </div>
                    <div class="col-6 col-md-3 border-start d-none d-md-block">
                        <div class="small fw-bold">@Model.Stats.TotalReach</div>
                        <div class="small text-muted opacity-75">Lượt tiếp cận</div>
                    </div>
                    <div class="col-6 col-md-3 border-start d-none d-md-block">
                        <div class="small fw-bold">100%</div>
                        <div class="small text-muted opacity-75">Cam kết thật</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
