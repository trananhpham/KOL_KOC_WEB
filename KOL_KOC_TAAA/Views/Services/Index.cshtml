@{
    Layout = "_LayoutLuxury";
    ViewData["Title"] = "Dịch vụ Chuyên nghiệp - KOL/KOC Marketplace";
}

<section class="services-hero py-5" style="background: var(--lux-bg-stone); border-bottom: var(--lux-border);">
    <div class="container py-5 text-center">
        <span class="lux-cap mb-3 d-block" data-reveal="fade-up">Giải pháp toàn diện</span>
        <h1 class="lux-h1 mb-4" data-reveal="fade-up">Nâng tầm <span class="text-gradient-gold">Thương hiệu</span> của bạn</h1>
        <p class="text-muted fs-5 mx-auto" style="max-width: 700px;" data-reveal="fade-up">
            Từ việc xây dựng nhận diện thương hiệu đến các chiến dịch chuyển đổi cao, chúng tôi kết nối bạn với những tài năng sáng tạo nhất.
        </p>
    </div>
</section>

<div class="container py-5 mt-5">
    <div class="row g-5">
        <!-- Service Type 1: Content Branding -->
        <div class="col-lg-6" data-reveal="fade-right">
            <div class="lux-surface p-5 h-100 d-flex flex-column">
                <div class="mb-4">
                    <i class="bi bi-camera-reels text-gold fs-1"></i>
                </div>
                <h2 class="lux-h2">Content Branding</h2>
                <p class="text-muted flex-grow-1">
                    Sản xuất video review, unboxing, hoặc nội dung sáng tạo phong cách editorial. Đưa sản phẩm của bạn vào câu chuyện của tài năng một cách tự nhiên và lôi cuốn.
                </p>
                <ul class="list-unstyled mb-5">
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Review sản phẩm chuyên sâu</li>
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Content Storytelling</li>
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Chụp ảnh Lifestyle Editorial</li>
                </ul>
                <a asp-controller="Discovery" asp-action="Index" asp-route-Category="Content" class="lux-btn-primary w-fit">TÌM KIẾM TALENTS</a>
            </div>
        </div>

        <!-- Service Type 2: Social Seeding -->
        <div class="col-lg-6" data-reveal="fade-left">
            <div class="lux-surface p-5 h-100 d-flex flex-column">
                <div class="mb-4">
                    <i class="bi bi-megaphone text-gold fs-1"></i>
                </div>
                <h2 class="lux-h2">Social Seeding & Buzz</h2>
                <p class="text-muted flex-grow-1">
                    Tạo ra sự bùng nổ trên các nền tảng mạng xã hội thông qua mạng lưới KOC hùng hậu. Phù hợp cho việc lan tỏa thông điệp dự án mới hoặc sự kiện.
                </p>
                <ul class="list-unstyled mb-5">
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Lan tỏa hashtag chiến dịch</li>
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Tăng tương tác tự nhiên</li>
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Viral seeding trên Group/Page</li>
                </ul>
                <a asp-controller="Discovery" asp-action="Index" asp-route-Category="Seeding" class="lux-btn-outline w-fit">KHÁM PHÁ NGAY</a>
            </div>
        </div>

        <!-- Service Type 3: Livestream E-commerce -->
        <div class="col-lg-6" data-reveal="fade-right">
            <div class="lux-surface p-5 h-100 d-flex flex-column">
                <div class="mb-4">
                    <i class="bi bi-broadcast text-gold fs-1"></i>
                </div>
                <h2 class="lux-h2">Livestream E-commerce</h2>
                <p class="text-muted flex-grow-1">
                    Trực tiếp chốt đơn với các "Livestream Stars". Giải pháp tăng doanh số thần tốc trên TikTok Shop, Shopee Live thông qua các phiên live được lên kịch bản bài bản.
                </p>
                <ul class="list-unstyled mb-5">
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Livestream TikTok/Shopee</li>
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Host sự kiện trực tuyến</li>
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Đào tạo Script Livestream</li>
                </ul>
                <a asp-controller="Discovery" asp-action="Index" asp-route-Category="Livestream" class="lux-btn-outline w-fit">XEM DANH SÁCH STARS</a>
            </div>
        </div>

        <!-- Service Type 4: Brand Ambassador -->
        <div class="col-lg-6" data-reveal="fade-left">
            <div class="lux-surface p-5 h-100 d-flex flex-column" style="border-color: var(--lux-accent-gold) !important;">
                <div class="mb-4">
                    <i class="bi bi-gem text-gold fs-1"></i>
                </div>
                <h2 class="lux-h2">Elite Brand Ambassador</h2>
                <p class="text-muted flex-grow-1">
                    Kết nối dài hạn với các Celeb và Influencer hạng A. Xây dựng sự tin tưởng vững chắc và vị thế cao cấp cho thương hiệu thông qua gương mặt đại diện uy tín.
                </p>
                <ul class="list-unstyled mb-5">
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Ký kết gương mặt đại diện</li>
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Tham gia các Big Campaign</li>
                    <li class="mb-2"><i class="bi bi-check2 text-gold me-2"></i> Tư vấn chiến lược hình ảnh</li>
                </ul>
                <button class="lux-btn-primary w-fit">LIÊN HỆ TƯ VẤN VIP</button>
            </div>
        </div>
    </div>
</div>

<section class="cta-section py-5 my-5">
    <div class="container">
        <div class="bg-indigo text-white p-5 rounded-4 text-center" data-reveal="zoom-in">
            <h2 class="lux-h1 text-white mb-4">Bạn cần giải pháp thiết kế riêng?</h2>
            <p class="mb-5 opacity-75">Hãy gửi cho chúng tôi Brief của bạn, đội ngũ chuyên gia sẽ tư vấn gói nhân sự phù hợp nhất.</p>
            <div class="d-flex gap-3 justify-content-center">
                <button class="lux-btn-primary" style="background: white; color: var(--lux-primary-indigo);">GỬI BRIEF NGAY</button>
                <button class="lux-btn-outline" style="border-color: white; color: white;">HỖ TRỢ TRỰC TUYẾN</button>
            </div>
        </div>
    </div>
</section>
