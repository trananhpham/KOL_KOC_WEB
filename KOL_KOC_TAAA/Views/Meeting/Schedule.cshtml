@model KOL_KOC_TAAA.ViewModels.CreateMeetingViewModel
@{
    Layout = "_LayoutLuxury";
    ViewData["Title"] = "Đặt lịch họp - KOL Market";
}

<div class="container py-5">
    <div class="mb-5" data-reveal="fade-up">
        <a asp-controller="Booking" asp-action="Detail" asp-route-id="@Model.BookingId" class="lux-link small mb-3 d-inline-block"><i class="bi bi-arrow-left me-1"></i> Quay lại chi tiết đơn hàng</a>
        <h1 class="lux-h1">Đặt lịch <span class="text-gradient-gold">Họp thảo luận</span></h1>
        <p class="text-muted">Lên lịch gặp mặt trực tuyến để thống nhất các yêu cầu và kịch bản chi tiết.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7" data-reveal="fade-up">
            <div class="lux-surface p-5">
                <form asp-action="Schedule" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="BookingId" />
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>

                    <div class="mb-4">
                        <label asp-for="Title" class="lux-cap mb-2 d-block"></label>
                        <input asp-for="Title" class="lux-input w-100" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Agenda" class="lux-cap mb-2 d-block"></label>
                        <textarea asp-for="Agenda" class="lux-input w-100" rows="4" placeholder="Nội dung chính cần trao đổi..."></textarea>
                        <span asp-validation-for="Agenda" class="text-danger small"></span>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="StartTime" class="lux-cap mb-2 d-block"></label>
                            <input asp-for="StartTime" type="datetime-local" class="lux-input w-100" />
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndTime" class="lux-cap mb-2 d-block"></label>
                            <input asp-for="EndTime" type="datetime-local" class="lux-input w-100" />
                            <span asp-validation-for="EndTime" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="MeetingUrl" class="lux-cap mb-2 d-block"></label>
                        <input asp-for="MeetingUrl" class="lux-input w-100" placeholder="Link Zoom, Google Meet hoặc Teams" />
                        <span asp-validation-for="MeetingUrl" class="text-danger small"></span>
                    </div>

                    <div class="pt-4 border-top">
                        <button type="submit" class="lux-btn-primary w-100">XÁC NHẬN LÊN LỊCH HỌP</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
