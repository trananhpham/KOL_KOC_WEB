@model KOL_KOC_TAAA.ViewModels.ContractDraftViewModel
@{
    ViewData["Title"] = "Soạn thảo Hợp đồng";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Soạn thảo hợp đồng cung cấp dịch vụ</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6 border-end">
                            <small class="text-muted d-block text-uppercase">Bên thuê (Brand)</small>
                            <h6 class="mb-0">@Model.BrandName</h6>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted d-block text-uppercase">Bên thực hiện (KOL)</small>
                            <h6 class="mb-0">@Model.KolName</h6>
                        </div>
                    </div>

                    <form asp-action="Draft" method="post">
                        <input type="hidden" asp-for="BookingId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TermsText" class="form-label fw-bold"></label>
                            <textarea asp-for="TermsText" class="form-control" rows="12" style="font-family: 'Courier New', Courier, monospace; font-size: 0.9rem;"></textarea>
                            <span asp-validation-for="TermsText" class="text-danger"></span>
                            <div class="form-text">Lưu ý: Bạn có thể chỉnh sửa các điều khoản để phù hợp với thỏa thuận thực tế.</div>
                        </div>

                        <div class="alert alert-info py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>Giá trị hợp đồng:</span>
                                <strong class="fs-5">@Model.TotalAmount.ToString("N0") @Model.Currency</strong>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a href="javascript:history.back()" class="btn btn-outline-secondary me-md-2">Hủy bỏ</a>
                            <button type="submit" class="btn btn-dark px-5">Gửi bản thảo hợp đồng</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
