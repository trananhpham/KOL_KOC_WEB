@model KOL_KOC_TAAA.Models.Contract
@{
    ViewData["Title"] = "Chi tiết Hợp đồng";
    Layout = "_LayoutDashboard";
    var userId = (Guid)ViewBag.CurrentUserId;
    var hasSigned = Model.ContractSignatures.Any(s => s.UserId == userId);
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 class="h4 fw-bold mb-1">@Model.Title</h2>
        <p class="text-muted small">Mã hợp đồng: @Model.Id.ToString().ToUpper()</p>
    </div>
    <div>
        <span class="badge rounded-pill @(Model.Status == "signed" ? "bg-success" : "bg-warning") px-3 py-2">
            @Model.Status.ToUpper()
        </span>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 mb-4 rounded-4">@TempData["SuccessMessage"]</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <!-- Contract Content -->
        <div class="dash-card p-5 bg-white shadow-sm border-0 mb-4" style="min-height: 600px; border-radius: 24px;">
            <div class="contract-body overflow-auto" style="line-height: 1.8;">
                @Html.Raw(Model.TermsText.Replace("\n", "<br/>"))
            </div>
            
            <hr class="my-5 opacity-10" />
            
            <!-- Signatures Section -->
            <div class="row g-4 mt-5">
                <div class="col-md-6 border-end">
                    <div class="lux-cap text-muted mb-3" style="font-size: 0.65rem;">BÊN A (NHÃN HÀNG)</div>
                    @{
                        var customerSig = Model.ContractSignatures.FirstOrDefault(s => s.UserId == Model.Booking.CustomerUserId);
                    }
                    @if (customerSig != null)
                    {
                        <div class="mb-2 text-center py-3">
                            <img src="@customerSig.SignatureData" alt="Signature Customer" style="max-height: 60px; filter: grayscale(1) contrast(1.5);" />
                        </div>
                        <div class="small fw-bold text-center">@Model.Booking.CustomerUser?.FullName</div>
                        <div class="text-muted text-center" style="font-size: 0.6rem;">Đã ký lúc @customerSig.SignedAt.ToString("HH:mm dd/MM/yyyy")</div>
                    }
                    else
                    {
                        <div class="py-4 text-center text-muted italic small opacity-50">Đang chờ ký...</div>
                    }
                </div>
                <div class="col-md-6">
                    <div class="lux-cap text-muted mb-3" style="font-size: 0.65rem;">BÊN B (KOL/KOC)</div>
                    @{
                        var kolSig = Model.ContractSignatures.FirstOrDefault(s => s.UserId == Model.Booking.KolUserId);
                    }
                    @if (kolSig != null)
                    {
                        <div class="mb-2 text-center py-3">
                            <img src="@kolSig.SignatureData" alt="Signature KOL" style="max-height: 60px; filter: grayscale(1) contrast(1.5);" />
                        </div>
                        <div class="small fw-bold text-center">@Model.Booking.KolUser?.User?.FullName</div>
                        <div class="text-muted text-center" style="font-size: 0.6rem;">Đã ký lúc @kolSig.SignedAt.ToString("HH:mm dd/MM/yyyy")</div>
                    }
                    else
                    {
                        <div class="py-4 text-center text-muted italic small opacity-50">Đang chờ ký...</div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="sticky-top" style="top: 100px;">
            <div class="dash-card p-4 border-0 shadow-sm mb-4">
                <h6 class="fw-bold mb-3">Thông tin đơn hàng</h6>
                <div class="mb-3">
                    <div class="text-muted small">Chiến dịch</div>
                    <div class="fw-bold">@Model.Booking.BookingRequest?.Title</div>
                </div>
                <div class="mb-3">
                    <div class="text-muted small">Giá trị hợp đồng</div>
                    <div class="h5 fw-bold text-primary">@Model.Booking.TotalAmount.ToString("N0") @Model.Booking.Currency</div>
                </div>
                <div class="mb-0">
                    <div class="text-muted small">Phí nền tảng (10%)</div>
                    <div class="small fw-bold">@Model.Booking.PlatformFee.ToString("N0") @Model.Booking.Currency</div>
                </div>
            </div>

            @if (!hasSigned)
            {
                <div class="dash-card p-4 border-0 shadow-sm bg-indigo-subtle">
                    <h6 class="fw-bold mb-3 text-primary">Xác nhận ký kết</h6>
                    <p class="small text-muted mb-4">Vui lòng đọc kỹ các điều khoản trước khi ký tên.</p>
                    
                    <!-- Simplified Signature Pad using Canvas -->
                    <div class="mb-3 bg-white border rounded-4 p-2">
                        <canvas id="sig-canvas" width="300" height="150" class="w-100" style="cursor: crosshair; touch-action: none;"></canvas>
                        <div class="text-end">
                            <button type="button" class="btn btn-link text-decoration-none text-muted p-0 small" id="sig-clear">Xóa chữ ký</button>
                        </div>
                    </div>

                    <form id="sig-form" asp-action="Sign" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="contractId" value="@Model.Id" />
                        <input type="hidden" id="signatureData" name="signatureData" />
                        <button type="button" class="lux-btn-primary w-100 py-3" id="sig-submit">
                            Ký tên ngay <i class="bi bi-pencil-fill ms-2"></i>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="dash-card p-4 border-0 shadow-sm bg-success-subtle text-center">
                    <div class="text-success mb-2"><i class="bi bi-patch-check-fill fs-3"></i></div>
                    <h6 class="fw-bold text-success mb-0">Bạn đã ký hợp đồng này</h6>
                    <p class="small text-muted mt-2 mb-0">Hợp đồng sẽ có giá trị pháp lý sau khi cả hai bên hoàn tất việc ký kết.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const canvas = document.getElementById('sig-canvas');
        if (canvas) {
            const ctx = canvas.getContext('2d');
            let drawing = false;

            canvas.addEventListener('mousedown', () => drawing = true);
            canvas.addEventListener('mouseup', () => { drawing = false; ctx.beginPath(); });
            canvas.addEventListener('mousemove', draw);

            function draw(e) {
                if (!drawing) return;
                ctx.lineWidth = 2;
                ctx.lineCap = 'round';
                ctx.strokeStyle = '#000';

                const rect = canvas.getBoundingClientRect();
                ctx.lineTo(e.clientX - rect.left, e.clientY - rect.top);
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(e.clientX - rect.left, e.clientY - rect.top);
            }

            document.getElementById('sig-clear').addEventListener('click', () => {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
            });

            document.getElementById('sig-submit').addEventListener('click', () => {
                const dataUrl = canvas.toDataURL();
                document.getElementById('signatureData').value = dataUrl;
                document.getElementById('sig-form').submit();
            });
        }
    </script>
}

<style>
    .contract-body { color: #334155; }
    .contract-body h1, .contract-body h2 { font-weight: 800; color: #000; margin-top: 1.5rem; margin-bottom: 1rem; }
    .lux-btn-primary { background: var(--lux-primary-indigo); color: #fff; border: none; border-radius: 50px; font-weight: 600; transition: all 0.3s ease; }
    .lux-btn-primary:hover { opacity: 0.9; transform: translateY(-2px); }
</style>
