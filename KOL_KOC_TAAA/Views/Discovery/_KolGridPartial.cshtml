@model List<KOL_KOC_TAAA.ViewModels.PublicKolProfileViewModel>

@if (Model == null || !Model.Any())
{
    <div class="col-12 py-5 text-center">
        <div class="py-5">
            <i class="bi bi-search text-muted opacity-25" style="font-size: 4rem;"></i>
            <h3 class="mt-4 lux-h2">Không tìm thấy tài năng nào</h3>
            <p class="text-muted">Hãy thử thay đổi bộ lọc hoặc từ khóa tìm kiếm của bạn.</p>
            <button type="button" class="lux-btn-outline mt-3" onclick="resetFilters()">Xóa tất cả bộ lọc</button>
        </div>
    </div>
}
else
{
    foreach (var kol in Model)
    {
        <div class="col-sm-6 col-lg-4 col-xl-4 mb-4" data-reveal="fade-up">
            @await Html.PartialAsync("~/Views/Home/Partials/_PremiumKOLCard.cshtml", kol)
        </div>
    }
}
