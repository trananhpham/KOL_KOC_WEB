@model List<KOL_KOC_TAAA.Models.Notification>
@{
    Layout = "_LayoutLuxury";
    ViewData["Title"] = "Thông báo - KOL Market";
}

<div class="container py-5">
    <div class="mb-5 d-flex align-items-center justify-content-between" data-reveal="fade-up">
        <div>
            <h1 class="lux-h1 mb-1">Cập nhật <span class="text-gradient-gold">Thông báo</span></h1>
            <p class="text-muted">Theo dõi mọi hoạt động quan trọng về chiến dịch và tài khoản của bạn.</p>
        </div>
        <form asp-action="MarkAllAsRead" method="post">
            <button type="submit" class="lux-btn-outline btn-sm">ĐÁNH DẤU TẤT CẢ ĐÃ ĐỌC</button>
        </form>
    </div>

    <div class="lux-surface p-0 overflow-hidden" data-reveal="fade-up">
        @if (Model.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var note in Model)
                {
                    <div class="list-group-item p-4 p-xl-5 border-bottom @(note.ReadAt == null ? "bg-gold-subtle" : "")">
                        <div class="d-flex gap-4">
                            <div class="note-icon bg-indigo-subtle rounded-circle d-flex align-items-center justify-content-center text-primary" style="width: 50px; height: 50px; flex-shrink: 0;">
                                <i class="bi bi-bell-fill fs-5"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h6 class="fw-bold mb-0">@note.Title</h6>
                                    <span class="smaller text-muted">@note.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                <p class="text-muted mb-0">@note.Body</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="p-5 text-center text-muted">
                <i class="bi bi-bell-slash display-1 opacity-10 d-block mb-3"></i>
                <p>Bạn không có thông báo nào.</p>
            </div>
        }
    </div>
</div>

<style>
    .bg-gold-subtle { background-color: rgba(212, 175, 55, 0.03) !important; border-left: 4px solid var(--lux-accent-gold) !important; }
</style>
