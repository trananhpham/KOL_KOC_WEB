@model IEnumerable<KOL_KOC_TAAA.Models.RateCard>
@{
    ViewData["Title"] = "Bảng giá dịch vụ";
    Layout = "_LayoutDashboard";
}

<div class="mb-4 d-flex justify-content-between align-items-end">
    <div>
        <h2 class="h4 fw-bold mb-1">Bảng giá (Rate Cards)</h2>
        <p class="text-muted small mb-0">Niêm yết giá dịch vụ giúp tiết kiệm 70% thời gian đàm phán.</p>
    </div>
    <button class="btn btn-dark rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createRateCardModal">
        <i class="bi bi-plus-lg me-2"></i> Tạo bảng giá mới
    </button>
</div>

<div class="row g-4">
    @if (Model != null && Model.Any())
    {
        @foreach (var rc in Model)
        {
            <div class="col-12">
                <div class="dash-card">
                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                        <div class="d-flex align-items-center gap-3">
                            <div class="dash-badge @(rc.IsActive == true ? "bg-success" : "bg-secondary") text-white">@(rc.IsActive == true ? "Active" : "Archived")</div>
                            <h5 class="fw-bold mb-0">@rc.Title</h5>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-dark btn-sm rounded-circle"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-outline-danger btn-sm rounded-circle"><i class="bi bi-trash"></i></button>
                        </div>
                    </div>
                    
                    <div class="row g-3">
                        @if (rc.RateCardItems != null && rc.RateCardItems.Any())
                        {
                            @foreach (var item in rc.RateCardItems)
                            {
                                <div class="col-md-4">
                                    <div class="p-3 bg-light rounded-4 border">
                                        <div class="small text-muted mb-1">@item.ServiceType</div>
                                        <div class="h5 fw-bold mb-0">@item.UnitPrice.ToString("N0") <span class="small fw-normal">@rc.Currency</span></div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12">
                                <p class="small text-muted mb-0 italic">Chưa có hạng mục giá nào. <a href="#" class="fw-bold text-dark">Thêm hạng mục ngay.</a></p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="dash-card text-center py-5">
                <i class="bi bi-tags fs-1 text-muted opacity-25 mb-3 d-block"></i>
                <h5 class="fw-bold">Bạn chưa tạo bảng giá nào</h5>
                <button class="btn btn-outline-dark rounded-pill px-4 mt-2" data-bs-toggle="modal" data-bs-target="#createRateCardModal">Bắt đầu niêm yết giá</button>
            </div>
        </div>
    }
</div>

<!-- Create Rate Card Modal -->
<div class="modal fade" id="createRateCardModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold">Tạo bảng giá mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateRateCard" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="lux-cap mb-2" style="font-size: 0.7rem;">Tiêu đề bảng giá</label>
                        <input name="Title" class="lux-input w-100" placeholder="VD: Bảng giá TikTok 2024" required />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="lux-cap mb-2" style="font-size: 0.7rem;">Đơn vị tiền tệ</label>
                            <select name="Currency" class="form-select lux-input h-auto py-2">
                                <option value="VND">VND (₫)</option>
                                <option value="USD">USD ($)</option>
                            </select>
                        </div>
                        <div class="col-6 mb-3 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input name="IsActive" class="form-check-input" type="checkbox" value="true" checked>
                                <label class="form-check-label small">Kích hoạt</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="submit" class="lux-btn-primary w-100 py-3 mt-2">Tạo bảng giá <i class="bi bi-arrow-right ms-2"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>
