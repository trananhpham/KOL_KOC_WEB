@model KOL_KOC_TAAA.ViewModels.KolProfileEditViewModel
@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
}

<div class="container mt-4">
    <div class="row">
        <!-- Sidebar Menu -->
        <div class="col-md-3">
            <div class="list-group">
                <a asp-action="Index" class="list-group-item list-group-item-action">Tổng quan</a>
                <a asp-action="Edit" class="list-group-item list-group-item-action active">Chỉnh sửa hồ sơ</a>
                <a asp-action="Socials" class="list-group-item list-group-item-action">Mạng xã hội</a>
                <a asp-action="RateCards" class="list-group-item list-group-item-action">Bảng giá (Rate Cards)</a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">Chỉnh sửa hồ sơ</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="InfluencerType" class="control-label"></label>
                                    <select asp-for="InfluencerType" class="form-select">
                                        <option value="Nano">Nano Influencer (1k - 10k)</option>
                                        <option value="Micro">Micro Influencer (10k - 50k)</option>
                                        <option value="Macro">Macro Influencer (50k - 500k)</option>
                                        <option value="Mega">Mega Influencer (>500k)</option>
                                    </select>
                                    <span asp-validation-for="InfluencerType" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="MinBudget" class="control-label"></label>
                                    <div class="input-group">
                                        <input asp-for="MinBudget" class="form-control" type="number" step="100000" />
                                        <span class="input-group-text">VND</span>
                                    </div>
                                    <span asp-validation-for="MinBudget" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Gender" class="control-label"></label>
                                    <select asp-for="Gender" class="form-select">
                                        <option value="">Chọn giới tính...</option>
                                        <option value="Male">Nam</option>
                                        <option value="Female">Nữ</option>
                                        <option value="Other">Khác</option>
                                    </select>
                                    <span asp-validation-for="Gender" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Dob" class="control-label"></label>
                                    <input asp-for="Dob" class="form-control" type="date" />
                                    <span asp-validation-for="Dob" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="LocationCity" class="control-label"></label>
                                    <input asp-for="LocationCity" class="form-control" placeholder="Ví dụ: TP.Hồ Chí Minh" />
                                    <span asp-validation-for="LocationCity" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="LocationCountry" class="control-label"></label>
                                    <input asp-for="LocationCountry" class="form-control" placeholder="Ví dụ: Việt Nam" />
                                    <span asp-validation-for="LocationCountry" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Bio" class="control-label"></label>
                            <textarea asp-for="Bio" class="form-control" rows="4" placeholder="Viết giới thiệu về bạn, thế mạnh, kinh nghiệm..."></textarea>
                            <span asp-validation-for="Bio" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
