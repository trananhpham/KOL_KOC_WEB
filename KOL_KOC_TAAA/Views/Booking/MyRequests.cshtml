@model IEnumerable<KOL_KOC_TAAA.Models.BookingRequest>
@{
    ViewData["Title"] = "Yêu cầu đã gửi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Lịch sử Booking đã gửi</h3>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>KOL</th>
                        <th>Ngày gửi</th>
                        <th>Trạng thái</th>
                        <th>Ngày chiến dịch</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <p class="mb-0">Bạn chưa gửi yêu cầu booking nào.</p>
                                <a href="/" class="btn btn-primary mt-2">Khám phá KOL ngay</a>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@(item.KolUser?.User?.FullName ?? "KOL")</strong>
                            </td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @switch (item.Status.ToLower())
                                {
                                    case "pending":
                                        <span class="badge bg-warning text-dark">Chờ phản hồi</span>
                                        break;
                                    case "accepted":
                                        <span class="badge bg-success">Đã chấp nhận</span>
                                        break;
                                    case "declined":
                                        <span class="badge bg-danger">Đã từ chối</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@item.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                <small class="text-muted">@item.ProposedStartDate?.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td>
                                @if (item.Booking != null)
                                {
                                    <a asp-action="Details" asp-route-id="@item.Booking.Id" class="btn btn-sm btn-success">Bản hợp đồng</a>
                                }
                                <a asp-controller="Chat" asp-action="StartWithBooking" asp-route-bookingId="@item.Id" class="btn btn-sm btn-outline-primary">Chat</a>
                                <button class="btn btn-sm btn-outline-info">Chi tiết</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
