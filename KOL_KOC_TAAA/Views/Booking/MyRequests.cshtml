@model IEnumerable<KOL_KOC_TAAA.Models.BookingRequest>
@{
    ViewData["Title"] = "Yêu cầu của tôi";
    Layout = "_LayoutDashboard";
}

<div class="mb-4 d-flex justify-content-between align-items-end">
    <div>
        <h2 class="h4 fw-bold mb-1">Chiến dịch của tôi</h2>
        <p class="text-muted small mb-0">Theo dõi trạng thái các yêu cầu hợp tác bạn đã gửi.</p>
    </div>
    <a href="/" class="btn btn-dark rounded-pill px-4">
        <i class="bi bi-search me-2"></i> Khám phá thêm KOL
    </a>
</div>

<div class="dash-card p-0 overflow-hidden shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light border-bottom">
                <tr class="lux-cap text-muted" style="font-size: 0.65rem;">
                    <th class="ps-4 py-3">Đối tác KOL</th>
                    <th class="py-3">Chiến dịch / Dự án</th>
                    <th class="py-3">Ngân sách dự kiến</th>
                    <th class="py-3">Trạng thái</th>
                    <th class="py-3">Ngày gửi</th>
                    <th class="py-3 text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-sm rounded-circle bg-indigo-subtle d-flex align-items-center justify-content-center text-primary fw-bold" style="width: 32px; height: 32px; font-size: 0.75rem;">
                                        @if (!string.IsNullOrEmpty(item.KolUser?.User?.AvatarUrl))
                                        {
                                            <img src="@item.KolUser.User.AvatarUrl" class="w-100 h-100 rounded-circle" style="object-fit: cover;">
                                        }
                                        else
                                        {
                                            @(item.KolUser?.User?.FullName?[0..1] ?? "K")
                                        }
                                    </div>
                                    <span class="fw-bold small">@item.KolUser?.User?.FullName</span>
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold small mb-1">@item.Title</div>
                                <div class="text-muted" style="font-size: 0.7rem;">@item.BookingRequestItems.Count hạng mục</div>
                            </td>
                            <td>
                                <div class="small fw-bold">@item.BudgetMin?.ToString("N0") - @item.BudgetMax?.ToString("N0")</div>
                                <div class="text-muted" style="font-size: 0.65rem;">@item.Currency</div>
                            </td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        "sent" => "bg-primary-subtle text-primary",
                                        "accepted" => "bg-success-subtle text-success",
                                        "rejected" => "bg-danger-subtle text-danger",
                                        "finalized" => "bg-indigo text-white",
                                        _ => "bg-secondary-subtle text-secondary"
                                    };
                                }
                                <span class="badge rounded-pill @badgeClass px-3 py-2" style="font-size: 0.65rem; font-weight: 600;">
                                    @item.Status.ToUpper()
                                </span>
                            </td>
                            <td class="small text-muted">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                     @foreach(var conv in item.ChatConversations)
                                     {
                                         <a asp-controller="Chat" asp-action="Conversation" asp-route-id="@conv.Id" class="btn btn-outline-dark btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" title="Chat">
                                             <i class="bi bi-chat-text"></i>
                                         </a>
                                     }
                                     @if (item.Booking != null && item.Booking.Contracts.Any())
                                     {
                                         var contract = item.Booking.Contracts.OrderByDescending(c => c.Version).First();
                                         <a asp-controller="Contract" asp-action="Details" asp-route-id="@contract.Id" class="btn btn-outline-primary btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" title="Hợp đồng">
                                             <i class="bi bi-file-earmark-text"></i>
                                         </a>
                                         
                                         @if (item.Booking.Status == "contract_signed")
                                         {
                                             <a asp-action="Pay" asp-route-bookingId="@item.Booking.Id" class="btn btn-success btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" title="Thanh toán nạp Escrow">
                                                 <i class="bi bi-credit-card"></i>
                                             </a>
                                         }
                                     }
                                     <button class="btn btn-light btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" title="Chi tiết">
                                         <i class="bi bi-eye"></i>
                                     </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <div class="opacity-25 mb-3"><i class="bi bi-inbox fs-1"></i></div>
                            <p class="text-muted small">Bạn chưa có yêu cầu hợp tác nào.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .bg-indigo { background: var(--lux-primary-indigo); }
</style>
