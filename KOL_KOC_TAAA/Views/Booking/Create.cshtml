@model KOL_KOC_TAAA.ViewModels.CreateBookingRequestViewModel
@{
    ViewData["Title"] = $"Đặt lịch với {Model.KolName}";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Yêu cầu Booking mới</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">Bạn đang gửi yêu cầu hợp tác đến <strong>@Model.KolName</strong>. Vui lòng điền đầy đủ thông tin bên dưới.</p>
                    <hr>

                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="KolUserId" />
                        <input type="hidden" asp-for="KolName" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label font-weight-bold">Tiêu đề chiến dịch</label>
                            <input asp-for="Title" class="form-control" placeholder="Ví dụ: Chiến dịch Tết 2025 - Samsung S24" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Brief" class="form-label font-weight-bold">Mô tả công việc (Brief)</label>
                            <textarea asp-for="Brief" class="form-control" rows="4" placeholder="Mô tả cụ thể yêu cầu..."></textarea>
                            <span asp-validation-for="Brief" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ProposedStartDate" class="form-label font-weight-bold">Ngày bắt đầu dự kiến</label>
                                <input asp-for="ProposedStartDate" class="form-control" type="date" />
                                <span asp-validation-for="ProposedStartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ProposedEndDate" class="form-label font-weight-bold">Ngày kết thúc dự kiến</label>
                                <input asp-for="ProposedEndDate" class="form-control" type="date" />
                                <span asp-validation-for="ProposedEndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="javascript:history.back()" class="btn btn-outline-secondary me-md-2">Quay lại</a>
                            <button type="submit" class="btn btn-primary px-5">Gửi yêu cầu</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
