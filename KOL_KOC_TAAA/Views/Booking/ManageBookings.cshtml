@model IEnumerable<KOL_KOC_TAAA.Models.BookingRequest>
@{
    ViewData["Title"] = "Quản lý yêu cầu Booking";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Danh sách yêu cầu hợp tác</h3>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Người gửi (Brand)</th>
                        <th>Ngày gửi</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">Chưa có yêu cầu nào được gửi đến bạn.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@(item.CustomerUser?.FullName ?? item.CustomerUser?.Email ?? "Khách hàng")</strong>
                                <br/><small class="text-muted">@(item.Brief?.Length > 50 ? item.Brief.Substring(0, 50) + "..." : item.Brief)</small>
                            </td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @switch (item.Status.ToLower())
                                {
                                    case "pending":
                                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                        break;
                                    case "accepted":
                                        <span class="badge bg-success">Đã chấp nhận</span>
                                        break;
                                    case "declined":
                                        <span class="badge bg-danger">Đã từ chối</span>
                                        break;
                                    case "completed":
                                        <span class="badge bg-primary">Hoàn thành</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@item.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                @if (item.Status.ToLower() == "pending")
                                {
                                    <form asp-action="Respond" method="post" style="display:inline;">
                                        <input type="hidden" name="requestId" value="@item.Id" />
                                        <input type="hidden" name="status" value="accepted" />
                                        <button type="submit" class="btn btn-sm btn-success">Chấp nhận</button>
                                    </form>
                                    <form asp-action="Respond" method="post" style="display:inline;">
                                        <input type="hidden" name="requestId" value="@item.Id" />
                                        <input type="hidden" name="status" value="declined" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Từ chối</button>
                                    </form>
                                    <a asp-controller="Chat" asp-action="StartWithBooking" asp-route-bookingId="@item.Id" class="btn btn-sm btn-outline-primary">Chat</a>
                                }
                                @if (item.Booking != null)
                                {
                                    <a asp-action="Details" asp-route-id="@item.Booking.Id" class="btn btn-sm btn-success">Xem đơn hàng</a>
                                }
                                <button class="btn btn-sm btn-outline-info">Chi tiết</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
