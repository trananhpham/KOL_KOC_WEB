@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_LayoutDashboard";
}

<div class="mb-4">
    <h2 class="h4 fw-bold mb-1">Tổng quan nền tảng</h2>
    <p class="text-muted small">Kiểm soát hoạt động kinh doanh toàn sàn.</p>
</div>

<div class="row g-4 mb-5">
    <!-- Stat Cards -->
    <div class="col-md-3">
        <div class="dash-card p-4 text-center">
            <div class="lux-cap mb-2" style="font-size: 0.6rem;">Người dùng</div>
            <div class="h3 fw-bold">@ViewBag.UserCount</div>
            <div class="text-success small"><i class="bi bi-arrow-up-short"></i> 12% tháng này</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="dash-card p-4 text-center">
            <div class="lux-cap mb-2" style="font-size: 0.6rem;">Doanh thu phí sàn</div>
            <div class="h3 fw-bold">@(((decimal)ViewBag.TotalRevenue).ToString("N0")) <small class="h6 fw-normal">VND</small></div>
            <div class="text-indigo small">Từ các booking thành công</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="dash-card p-4 text-center">
            <div class="lux-cap mb-2" style="font-size: 0.6rem;">KOL / KOC</div>
            <div class="h3 fw-bold">@ViewBag.KolCount</div>
            <div class="text-muted small">Cộng đồng tài năng</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="dash-card p-4 text-center border-warning">
            <div class="lux-cap mb-2 text-warning" style="font-size: 0.6rem;">Yêu cầu rút tiền</div>
            <div class="h3 fw-bold text-warning">@ViewBag.PendingPayouts</div>
            <a asp-action="PayoutRequests" class="small text-decoration-none">Xem danh sách <i class="bi bi-chevron-right"></i></a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="dash-card h-100 p-5 bg-white shadow-sm border-0 d-flex flex-column justify-content-center align-items-center">
            <i class="bi bi-graph-up-arrow display-1 text-indigo mb-4 opacity-25"></i>
            <h5 class="fw-bold">Biểu đồ doanh thu (Planned)</h5>
            <p class="text-muted small text-center px-5">Tích hợp Chart.js để hiển thị xu hướng tăng trưởng doanh thu từ phí dịch vụ và số lượng đơn hàng theo thời gian.</p>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="dash-card p-4 h-100">
            <h6 class="fw-bold mb-4">Lối tắt quản trị</h6>
            <div class="list-group list-group-flush">
                <a asp-action="KolManagement" class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;"><i class="bi bi-people"></i></div>
                    <div>
                        <div class="small fw-bold">Quản lý KOL</div>
                        <div class="text-muted" style="font-size: 0.65rem;">Duyệt hồ sơ và thống kê KOL</div>
                    </div>
                </a>
                <a asp-action="PayoutRequests" class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;"><i class="bi bi-bank"></i></div>
                    <div>
                        <div class="small fw-bold">Phê duyệt rút tiền</div>
                        <div class="text-muted" style="font-size: 0.65rem;">Xử lý giao dịch thu nhập</div>
                    </div>
                </a>
                <a asp-action="Disputes" class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;"><i class="bi bi-exclamation-triangle"></i></div>
                    <div>
                        <div class="small fw-bold">Giải quyết tranh chấp</div>
                        <div class="text-muted" style="font-size: 0.65rem;">Khiếu nại và hoàn tiền</div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>
