@model IEnumerable<KOL_KOC_TAAA.Models.KolProfile>
@{
    ViewData["Title"] = "Quản lý KOL";
    Layout = "_LayoutDashboard";
}

<div class="mb-4 d-flex justify-content-between align-items-end">
    <div>
        <h2 class="h4 fw-bold mb-1">Cộng đồng KOL / KOC</h2>
        <p class="text-muted small mb-0">Danh sách và trạng thái phê duyệt của các nhà sáng tạo nội dung.</p>
    </div>
</div>

<div class="dash-card p-0 overflow-hidden shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light border-bottom">
                <tr class="lux-cap text-muted" style="font-size: 0.65rem;">
                    <th class="ps-4 py-3">KOL / KOC</th>
                    <th class="py-3">Danh mục</th>
                    <th class="py-3">Thành phố</th>
                    <th class="py-3">Trạng thái</th>
                    <th class="py-3">Ngày gia nhập</th>
                    <th class="py-3 text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-sm rounded-circle bg-indigo-subtle d-flex align-items-center justify-content-center text-primary fw-bold" style="width: 38px; height: 38px; font-size: 0.85rem;">
                                    @if (!string.IsNullOrEmpty(item.User?.AvatarUrl))
                                    {
                                        <img src="@item.User.AvatarUrl" class="w-100 h-100 rounded-circle" style="object-fit: cover;">
                                    }
                                    else
                                    {
                                        @(item.User?.FullName?[0..1] ?? "K")
                                    }
                                </div>
                                <div>
                                    <div class="fw-bold small">@item.User?.FullName</div>
                                    <div class="text-muted" style="font-size: 0.65rem;">@item.User?.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="small">@item.InfluencerType</td>
                        <td class="small">@item.LocationCity</td>
                        <td>
                            <span class="badge rounded-pill bg-success-subtle text-success px-3 py-1" style="font-size: 0.6rem;">ACTIVE</span>
                        </td>
                        <td class="small text-muted">@item.User?.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                 <button class="btn btn-light btn-sm rounded-pill px-3 py-1 opacity-75" style="font-size: 0.7rem;">Chỉnh sửa</button>
                                 <button class="btn btn-outline-danger btn-sm rounded-pill px-3 py-1" style="font-size: 0.7rem;">Khóa</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
