@model IEnumerable<KOL_KOC_TAAA.Models.Dispute>
@{
    ViewData["Title"] = "Quản lý Tranh chấp";
    Layout = "_LayoutDashboard";
}

<div class="mb-4">
    <h2 class="h4 fw-bold mb-1">Tranh chấp & Khiếu nại</h2>
    <p class="text-muted small">Giải quyết các vấn đề phát sinh trong quá trình thực hiện hợp đồng.</p>
</div>

<div class="dash-card p-0 overflow-hidden shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light border-bottom">
                <tr class="lux-cap text-muted" style="font-size: 0.65rem;">
                    <th class="ps-4 py-3">Mã đơn hàng</th>
                    <th class="py-3">Người khiếu nại</th>
                    <th class="py-3">Lý do</th>
                    <th class="py-3">Trạng thái</th>
                    <th class="py-3">Ngày tạo</th>
                    <th class="py-3 text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold small text-primary">#@item.BookingId.ToString()[..8].ToUpper()</span>
                            </td>
                            <td>
                                <div class="fw-bold small">@item.RaisedByUser?.FullName</div>
                                <div class="text-muted" style="font-size: 0.65rem;">@item.RaisedByUser?.Email</div>
                            </td>
                            <td class="small text-muted" style="max-width: 300px;">@item.Reason</td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch {
                                        "open" => "bg-danger-subtle text-danger",
                                        "resolved" => "bg-success-subtle text-success",
                                        _ => "bg-light text-muted"
                                    };
                                }
                                <span class="badge rounded-pill @badgeClass px-3 py-1" style="font-size: 0.6rem; font-weight: 700;">@item.Status.ToUpper()</span>
                            </td>
                            <td class="small text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-dark btn-sm rounded-pill px-4" style="font-size: 0.7rem;">Xử lý</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <p class="text-muted small italic">Hiện tại chưa có tranh chấp nào cần giải quyết.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
