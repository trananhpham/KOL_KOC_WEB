@model KOL_KOC_TAAA.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán đơn hàng";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h5 class="mb-0 fw-bold">Xác nhận thanh toán</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4 text-center">
                        <small class="text-muted text-uppercase">Thanh toán cho dịch vụ</small>
                        <h4 class="fw-bold mt-1">@Model.BookingTitle</h4>
                    </div>

                    <div class="p-3 bg-light rounded mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Giá trị booking:</span>
                            <span class="fw-bold">@Model.Amount.ToString("N0") @Model.Currency</span>
                        </div>
                        <div class="d-flex justify-content-between text-success">
                            <span>Phí nền tảng & Bảo hiểm:</span>
                            <span>Đã bao gồm</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between">
                            <h5 class="mb-0">Tổng cộng:</h5>
                            <h5 class="mb-0 fw-bold text-primary">@Model.Amount.ToString("N0") @Model.Currency</h5>
                        </div>
                    </div>

                    <form asp-action="ProcessCheckout" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="BookingId" />
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Chọn phương thức thanh toán</label>
                            
                            <div class="form-check border p-3 rounded mb-2 shadow-sm highlight-on-hover">
                                <input class="form-check-input ms-0" type="radio" asp-for="PaymentMethod" value="Momo" id="momo" checked>
                                <label class="form-check-label ms-4 d-block" for="momo">
                                    <div class="d-flex align-items-center">
                                        <img src="https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.png" alt="MoMo" style="height: 24px;" class="me-2">
                                        <strong>Ví MoMo</strong>
                                    </div>
                                    <small class="text-muted">Thanh toán qua ứng dụng MoMo (QR Code / ATM)</small>
                                </label>
                            </div>

                            <div class="form-check border p-3 rounded mb-2">
                                <input class="form-check-input ms-0" type="radio" asp-for="PaymentMethod" value="BankTransfer" id="bank">
                                <label class="form-check-label ms-4 d-block" for="bank">
                                    <strong>Chuyển khoản ngân hàng</strong>
                                    <br/><small class="text-muted">Vietcombank / Techcombank (Xử lý thủ công)</small>
                                </label>
                            </div>
                        </div>

                        <div class="alert alert-info py-2 small mb-4">
                            <i class="bi bi-shield-check"></i> Tiền của bạn sẽ được hệ thống giữ an toàn và chỉ thanh toán cho KOL sau khi bạn duyệt sản phẩm.
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold py-3">Thanh toán ngay</button>
                            <a href="javascript:history.back()" class="btn btn-link text-muted">Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
