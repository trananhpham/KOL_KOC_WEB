<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Luxury KOL Marketplace</title>
    
    <!-- Core CSS & Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- MỚI: Hệ thống Design Luxury -->
    <link rel="stylesheet" href="~/css/luxury-bento.css" asp-append-version="true" />
</head>
<body class="luxury-mode">
    
    <!-- Render Header Cấp Cao -->
    @await Html.PartialAsync("_LuxuryHeader")

    <main role="main">
        @RenderBody()
    </main>

    <!-- Render Footer Trầm Ấm -->
    @await Html.PartialAsync("_LuxuryFooter")

    <!-- Core Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Gắn sự kiện scroll nhỏ cho Header -->
    <script>
        $(window).scroll(function() {
            if ($(this).scrollTop() > 10) {
                $('.lux-header').addClass('scrolled');
            } else {
                $('.lux-header').removeClass('scrolled');
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
