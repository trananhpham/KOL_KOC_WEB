<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MarketPlace KOL/KOC</title>
    @{
        var metaDesc = ViewData["MetaDescription"] ?? "Nền tảng kết nối Doanh nghiệp với KOL/KOC hàng đầu Việt Nam. Tìm kiếm Influencer phù hợp cho chiến dịch marketing của bạn.";
        var ogImage = ViewData["OgImage"] ?? "/images/og-default.jpg";
    }
    <meta name="description" content="@metaDesc">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="@ViewData["Title"] - MarketPlace KOL/KOC">
    <meta property="og:description" content="@metaDesc">
    <meta property="og:image" content="@ogImage">
    
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KOL_KOC_TAAA.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">KOL_KOC_TAAA</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("KOL"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="KolProfile" asp-action="Index">Hồ sơ KOL</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Booking" asp-action="ManageBookings">Quản lý Booking</a>
                                </li>
                            }
                            @if (User.IsInRole("Customer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Booking" asp-action="MyRequests">Đơn đã đặt</a>
                                </li>
                            }
                            <li class="nav-item dropdown" id="notificationDropdown">
                                <a class="nav-link text-dark position-relative" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="notiBadge">
                                        0
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow p-0" style="width: 300px; max-height: 400px; overflow-y: auto;">
                                    <li class="p-2 border-bottom fw-bold small bg-light">Thông báo mới nhất</li>
                                    <div id="notiList">
                                        <li class="p-3 text-center text-muted small">Đang tải...</li>
                                    </div>
                                    <li><hr class="dropdown-divider m-0"></li>
                                    <li class="p-2 text-center small"><a href="#" class="text-decoration-none">Xem tất cả</a></li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Chat" asp-action="Index">Tin nhắn</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Wallet" asp-action="Index">Ví tiền</a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Quản trị</a>
                                </li>
                            }
                            <li class="nav-item">
                                <span class="nav-link text-dark">Xin chào, @Context.Session.GetString("UserName")!</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="form-inline">
                                    <button type="submit" class="nav-link btn btn-link text-dark" style="border: none; background: none; margin: 0; padding-top: 8px;">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Auth" asp-action="Register">Đăng ký</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - KOL_KOC_TAAA - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() {
            function loadNotifications() {
                $.get('/Notification/GetLatest', function(data) {
                    if (data && data.length > 0) {
                        $('#notiBadge').text(data.length).removeClass('d-none');
                        var html = '';
                        data.forEach(function(n) {
                            html += `<li class="p-2 border-bottom">
                                        <div class="small fw-bold">${n.title}</div>
                                        <div class="small text-muted">${n.body || ''}</div>
                                        <div class="text-end" style="font-size: 0.7rem;">${new Date(n.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</div>
                                     </li>`;
                        });
                        $('#notiList').html(html);
                    } else {
                        $('#notiList').html('<li class="p-3 text-center text-muted small">Không có thông báo mới</li>');
                        $('#notiBadge').addClass('d-none');
                    }
                });
            }
            if ($('#notificationDropdown').length) {
                loadNotifications();
                setInterval(loadNotifications, 60000); 
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
