<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MarketPlace KOL/KOC</title>
    @{
        var metaDesc = ViewData["MetaDescription"] ?? "Nền tảng kết nối Doanh nghiệp với KOL/KOC hàng đầu Việt Nam. Tìm kiếm Influencer phù hợp cho chiến dịch marketing của bạn.";
        var ogImage = ViewData["OgImage"] ?? "/images/og-default.jpg";
    }
    <meta name="description" content="@metaDesc">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="@ViewData["Title"] - MarketPlace KOL/KOC">
    <meta property="og:description" content="@metaDesc">
    <meta property="og:image" content="@ogImage">
    
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KOL_KOC_TAAA.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="sticky-top shadow-sm-custom">
        <nav class="navbar navbar-expand-lg navbar-glass py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-rocket-takeoff-fill me-2"></i>KOL Market
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link fw-medium px-3" asp-area="" asp-controller="Home" asp-action="Index">Khám phá</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("KOL"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-medium" asp-controller="KolProfile" asp-action="Index">Hồ sơ của tôi</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link fw-medium" asp-controller="Booking" asp-action="ManageBookings">Đơn hàng</a>
                                </li>
                            }
                            @if (User.IsInRole("Customer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-medium" asp-controller="Booking" asp-action="MyRequests">Lịch sử đặt</a>
                                </li>
                            }
                            <li class="nav-item dropdown" id="notificationDropdown">
                                <a class="nav-link position-relative px-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell-fill fs-5"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" id="notiBadge" style="margin-left: -8px; margin-top: 5px;">
                                        0
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-0 mt-3" style="width: 320px; border-radius: 1rem; overflow: hidden;">
                                    <li class="p-3 border-bottom fw-bold small bg-light text-uppercase letter-spacing-1">Thông báo</li>
                                    <div id="notiList" class="p-0" style="max-height: 350px; overflow-y: auto;">
                                        <li class="p-4 text-center text-muted small">Đang tải...</li>
                                    </div>
                                    <li class="p-2 text-center small bg-white border-top"><a href="#" class="text-primary text-decoration-none fw-semibold">Xem tất cả</a></li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-2" asp-controller="Chat" asp-action="Index" title="Tin nhắn">
                                    <i class="bi bi-chat-dots-fill fs-5"></i>
                                </a>
                            </li>
                            <li class="nav-item me-2">
                                <a class="nav-link px-2" asp-controller="Wallet" asp-action="Index" title="Ví tiền">
                                    <i class="bi bi-wallet2 fs-5"></i>
                                </a>
                            </li>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="btn btn-sm btn-outline-danger fw-bold rounded-pill px-3" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                                </li>
                            }

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="bg-primary-light rounded-circle d-flex align-items-center justify-content-center fw-bold text-primary" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                        @(Context.Session.GetString("UserName")?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <span class="small fw-semibold d-none d-xl-inline">@Context.Session.GetString("UserName")</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-3" style="border-radius: 1rem;">
                                    <li><a class="dropdown-item py-2" asp-controller="Wallet" asp-action="Index"><i class="bi bi-wallet2 me-2"></i>Số dư ví</a></li>
                                    <li><hr class="dropdown-divider opacity-50"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-medium" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-pill px-4 shadow-sm" asp-controller="Auth" asp-action="Register">Bắt đầu ngay</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="content-wrapper py-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container text-center text-md-start">
            <div class="row align-items-center">
                <div class="col-md-6 mb-3 mb-md-0">
                    <span class="fw-bold text-primary"><i class="bi bi-rocket-takeoff-fill me-1"></i>KOL Market</span>
                    <span class="text-muted ms-2 small">&copy; 2026. Nền tảng kết nối Influencer chuyên nghiệp.</span>
                </div>
                <div class="col-md-6 text-md-end">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none small me-3">Chính sách bảo mật</a>
                    <a href="#" class="text-muted text-decoration-none small">Trợ giúp</a>
                </div>
            </div>
        </div>
    </footer>
    <div class="ai-chat-widget">
        <div class="ai-chat-window" id="aiChatWindow">
            <div class="ai-chat-header">
                <div>
                    <h6 class="mb-0 fw-bold"><i class="bi bi-robot me-2"></i>KOL AI Assistant</h6>
                    <small class="opacity-75">Sẵn sàng hỗ trợ bạn 24/7</small>
                </div>
                <button type="button" class="btn-close btn-close-white" onclick="toggleChat()"></button>
            </div>
            <div class="ai-chat-body" id="aiChatBody">
                <div class="chat-message ai">
                    Chào bạn! Tôi là trợ lý AI của KOL Market. Tôi có thể giúp gì cho bạn hôm nay?
                </div>
            </div>
            <div class="ai-typing" id="aiTyping">AI đang suy nghĩ...</div>
            <div class="ai-chat-footer">
                <div class="chat-input-group">
                    <input type="text" id="chatInput" class="chat-input" placeholder="Nhập câu hỏi..." onkeypress="handleKeyPress(event)">
                    <button class="btn btn-primary btn-sm rounded-circle" onclick="sendMessage()"><i class="bi bi-send-fill"></i></button>
                </div>
            </div>
        </div>
        <button class="ai-chat-button" onclick="toggleChat()" title="Hỏi trợ lý AI">
            <i class="bi bi-chat-dots-fill"></i>
        </button>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleChat() {
            $('#aiChatWindow').fadeToggle(300).css('display', function(_, current) {
                return current === 'none' ? 'none' : 'flex';
            });
        }

        function handleKeyPress(e) {
            if (e.which === 13) sendMessage();
        }

        function sendMessage() {
            var input = $('#chatInput');
            var message = input.val().trim();
            if (!message) return;

            appendMessage('user', message);
            input.val('');
            $('#aiTyping').fadeIn();

            $.ajax({
                url: '/api/AiAssistant/chat',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ message: message }),
                success: function(data) {
                    $('#aiTyping').hide();
                    appendMessage('ai', data.response);
                },
                error: function() {
                    $('#aiTyping').hide();
                    appendMessage('ai', 'Xin lỗi, đã có lỗi xảy ra khi kết nối với AI.');
                }
            });
        }

        function appendMessage(role, text) {
            var chatBody = $('#aiChatBody');
            var msgHtml = `<div class="chat-message ${role}">${text}</div>`;
            chatBody.append(msgHtml);
            chatBody.scrollTop(chatBody[0].scrollHeight);
        }
    </script>
    <script>
        $(document).ready(function() {
            function loadNotifications() {
                $.get('/Notification/GetLatest', function(data) {
                    if (data && data.length > 0) {
                        $('#notiBadge').text(data.length).removeClass('d-none');
                        var html = '';
                        data.forEach(function(n) {
                            html += `<li class="p-3 border-bottom hover-bg-light transition">
                                        <div class="small fw-bold text-dark mb-1">${n.title}</div>
                                        <div class="small text-muted mb-2">${n.body || ''}</div>
                                        <div class="text-end text-primary" style="font-size: 0.65rem; font-weight: 500;">
                                            <i class="bi bi-clock me-1"></i>${new Date(n.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                                        </div>
                                     </li>`;
                        });
                        $('#notiList').html(html);
                    } else {
                        $('#notiList').html('<li class="p-3 text-center text-muted small">Không có thông báo mới</li>');
                        $('#notiBadge').addClass('d-none');
                    }
                });
            }
            if ($('#notificationDropdown').length) {
                loadNotifications();
                setInterval(loadNotifications, 60000); 
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
