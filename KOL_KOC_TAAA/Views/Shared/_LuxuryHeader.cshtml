@using Microsoft.AspNetCore.Http
<header class="lux-header sticky-top py-3">
    <div class="container d-flex align-items-center justify-content-between">
        
        <!-- Left: Branding & Core Nav -->
        <div class="d-flex align-items-center gap-5">
            <a class="text-decoration-none d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-asterisk" style="font-size: 1.4rem; color: var(--lux-accent-gold); margin-right: 12px;"></i>
                <span class="fs-5 fw-bold lux-h2 mb-0" style="letter-spacing: -0.5px;">KOL<span class="fw-light" style="color: var(--lux-text-dim);">MARKET</span></span>
            </a>

            <nav class="d-none d-lg-flex gap-4">
                <a href="#" class="lux-link fw-medium text-dark">Khám phá</a>
                <a href="#" class="lux-link fw-medium">Sáng tạo</a>
                <a href="#" class="lux-link fw-medium d-flex align-items-center">
                    Dịch vụ <span class="ms-1" style="font-size: 10px; color: var(--lux-accent-gold);">●</span>
                </a>
                <a href="#" class="lux-link fw-medium">Case Studies</a>
            </nav>
        </div>

        <!-- Middle: Global Search (Command Style) -->
        <div class="d-none d-xl-flex flex-grow-1 justify-content-center px-5" style="max-width: 500px;">
            <div class="w-100 position-relative">
                <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted" style="font-size: 0.85rem;"></i>
                <input type="text" class="lux-input w-100 ps-5" placeholder="Tìm kiếm tài năng, lĩnh vực...">
            </div>
        </div>

        <!-- Right: Actions & User -->
        <div class="d-flex align-items-center gap-4">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a href="#" class="lux-link position-relative d-flex align-items-center">
                    <i class="bi bi-bell-fill fs-5 opacity-75"></i>
                    <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle" style="width: 6px; height: 6px;"></span>
                </a>
                
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center gap-2 text-decoration-none dropdown-toggle lux-hover-lift" data-bs-toggle="dropdown" 
                       style="padding: 4px; border-radius: 50%; border: 1px solid var(--lux-border-thick);">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white" 
                             style="width: 34px; height: 34px; font-size: 0.75rem; background: var(--lux-primary-indigo);">
                            @(Context.Session.GetString("UserName")?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-3 p-2" style="border-radius: 12px; min-width: 240px; background: #fff;">
                        <li class="px-3 py-3 mb-2 rounded-3" style="background: var(--lux-bg-stone);">
                            <span class="d-block fw-bold lux-h2 fs-6">@Context.Session.GetString("UserName")</span>
                            <span class="d-block text-muted small mt-1">@User.Identity?.Name</span>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li><a class="dropdown-item py-2 px-3 rounded-2 fw-bold text-primary" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Bảng quản trị</a></li>
                        }
                        <li><a class="dropdown-item py-2 px-3 rounded-2" asp-controller="Wallet" asp-action="Index"><i class="bi bi-wallet2 me-2"></i>Tài chính cá nhân</a></li>
                        <li><a class="dropdown-item py-2 px-3 rounded-2" href="#"><i class="bi bi-gear me-2"></i>Cài đặt tài khoản</a></li>
                        <li><hr class="dropdown-divider opacity-50"></li>
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item py-2 px-3 text-danger rounded-2"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="lux-link fw-medium">Đăng nhập</a>
                <a asp-controller="Auth" asp-action="Register" class="lux-btn-primary">Tham gia ngay</a>
            }
        </div>
    </div>
</header>
