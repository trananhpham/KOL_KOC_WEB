@model KOL_KOC_TAAA.ViewModels.WalletIndexViewModel
@{
    ViewData["Title"] = "Ví tiền của bạn";
}

<div class="container mt-4">
    <div class="row">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="col-12 alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="col-12 alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="col-md-4">
            <div class="card bg-primary text-white shadow-sm mb-4">
                <div class="card-body p-4">
                    <h6 class="text-white-50 text-uppercase small fw-bold">Số dư hiện tại</h6>
                    <h2 class="fw-bold mb-3">@Model.Balance.ToString("N0") @Model.Currency</h2>
                    <div class="d-flex justify-content-between">
                        <small class="text-white-50">Tạm giữ: @Model.LockedBalance.ToString("N0")</small>
                    </div>
                </div>
            </div>

            @if (User.IsInRole("KOL"))
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-white fw-bold">Rút tiền mặt</div>
                    <div class="card-body">
                        <form asp-action="RequestPayout" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label small">Số tiền muốn rút</label>
                                <div class="input-group">
                                    <input type="number" name="amount" class="form-control" min="50000" step="1000" required />
                                    <span class="input-group-text">VND</span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small">Thông tin ngân hàng</label>
                                <textarea name="bankInfo" class="form-control" rows="3" placeholder="Tên NH, Số tài khoản, Tên chủ TK..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-outline-primary w-100">Gửi yêu cầu rút tiền</button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-bold">Lịch sử giao dịch</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Thời gian</th>
                                    <th>Nội dung</th>
                                    <th class="text-end">Số tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Transactions.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-4 text-muted">Chưa có giao dịch nào.</td>
                                    </tr>
                                }
                                @foreach (var t in Model.Transactions)
                                {
                                    <tr>
                                        <td class="small">@t.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                        <td>
                                            <div class="fw-bold">@t.Type</div>
                                            <div class="small text-muted">@t.Description</div>
                                        </td>
                                        <td class="text-end fw-bold @(t.Amount > 0 ? "text-success" : "text-danger")">
                                            @(t.Amount > 0 ? "+" : "")@t.Amount.ToString("N0")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
