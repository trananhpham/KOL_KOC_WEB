@model KOL_KOC_TAAA.Models.UserWallet
@{
    ViewData["Title"] = "Ví của tôi";
    Layout = "_LayoutDashboard";
    var ledger = (List<KOL_KOC_TAAA.Models.WalletLedger>)ViewBag.Ledger;
}

<div class="mb-4">
    <h2 class="h4 fw-bold mb-1">Tài chính & Ví tiền</h2>
    <p class="text-muted small">Quản lý thu nhập, số dư và lịch sử giao dịch của bạn.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 mb-4 rounded-4">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger border-0 mb-4 rounded-4">@TempData["ErrorMessage"]</div>
}

<div class="row g-4 mb-5">
    <!-- Balance Card -->
    <div class="col-md-6">
        <div class="dash-card p-5 bg-dark text-white shadow-xl position-relative overflow-hidden" style="border-radius: 32px;">
            <div class="position-relative z-1">
                <div class="lux-cap text-white-50 mb-3" style="font-size: 0.7rem;">Số dư khả dụng</div>
                <div class="display-5 fw-bold mb-4">@Model.Balance.ToString("N0") <small class="h6 fw-normal text-white-50">@Model.Currency</small></div>
                
                <div class="d-flex gap-4">
                    <div>
                        <div class="small text-white-50 mb-1">Đang tạm giữ</div>
                        <div class="fw-bold">@Model.LockedBalance.ToString("N0") <small class="text-white-50">@Model.Currency</small></div>
                    </div>
                    <div class="border-start border-white border-opacity-10 ps-4">
                        <div class="small text-white-50 mb-1">Tổng thu nhập</div>
                        <div class="fw-bold">@((Model.Balance + Model.LockedBalance).ToString("N0")) <small class="text-white-50">@Model.Currency</small></div>
                    </div>
                </div>
            </div>
            <!-- Decorative circle -->
            <div class="position-absolute top-0 end-0 p-5 mt-n5 me-n5 bg-white opacity-10 rounded-circle" style="width: 200px; height: 200px;"></div>
        </div>
    </div>

    <!-- Actions -->
    <div class="col-md-6">
        <div class="dash-card p-5 h-100 d-flex flex-column justify-content-center" style="border-radius: 32px;">
            <h5 class="fw-bold mb-4">Thao tác tài chính</h5>
            <div class="d-grid gap-3">
                <button class="btn btn-dark py-3 rounded-pill fw-bold" data-bs-toggle="modal" data-bs-target="#payoutModal">
                    <i class="bi bi-wallet2 me-2"></i> Rút tiền về ngân hàng
                </button>
                <button class="btn btn-outline-dark py-3 rounded-pill small" disabled>
                    <i class="bi bi-plus-circle me-2"></i> Nạp tiền vào ví (Sắp ra mắt)
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Transaction History -->
<div class="dash-card p-0 overflow-hidden shadow-sm border-0 mb-5">
    <div class="p-4 bg-white border-bottom d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0">Lịch sử giao dịch</h5>
        <button class="btn btn-link text-muted p-0 small text-decoration-none">Xem tất cả <i class="bi bi-chevron-right ms-1"></i></button>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr class="lux-cap text-muted" style="font-size: 0.65rem;">
                    <th class="ps-4 py-3">Loại giao dịch</th>
                    <th class="py-3">Mô tả</th>
                    <th class="py-3">Số tiền</th>
                    <th class="py-3">Ngày thực hiện</th>
                    <th class="py-3 text-end pe-4">Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @if (ledger != null && ledger.Any())
                {
                    @foreach (var entry in ledger)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: @(entry.TransactionType == "income" ? "#ecfdf5" : "#fff1f2"); color: @(entry.TransactionType == "income" ? "#10b981" : "#f43f5e");">
                                        <i class="bi bi-@(entry.TransactionType == "income" ? "arrow-down-left" : "arrow-up-right")" style="font-size: 0.8rem;"></i>
                                    </div>
                                    <span class="small fw-bold">@(entry.TransactionType == "income" ? "Tiền về" : "Rút tiền")</span>
                                </span>
                            </td>
                            <td class="small text-muted">@entry.Description</td>
                            <td>
                                <span class="fw-bold @(entry.TransactionType == "income" ? "text-success" : "text-danger")">
                                    @(entry.TransactionType == "income" ? "+" : "-")@Math.Abs(entry.Amount).ToString("N0")
                                </span>
                            </td>
                            <td class="small text-muted">@entry.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end pe-4">
                                <span class="badge rounded-pill bg-success-subtle text-success px-3 py-1" style="font-size: 0.6rem;">Hoàn tất</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <p class="text-muted small italic">Chưa có giao dịch nào được ghi nhận.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Payout Modal -->
<div class="modal fade" id="payoutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold">Yêu cầu rút tiền</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RequestPayout" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <p class="small text-muted mb-4 text-center p-3 bg-light rounded-4">Tiền sẽ được chuyển vào tài khoản ngân hàng của bạn trong vòng 48h làm việc.</p>
                    
                    <div class="mb-3">
                        <label class="lux-cap mb-2" style="font-size: 0.7rem;">Số tiền cần rút (VND)</label>
                        <input name="amount" type="number" class="lux-input w-100" placeholder="VD: 500000" min="100000" step="1000" required />
                    </div>
                    
                    <div class="mb-0">
                        <label class="lux-cap mb-2" style="font-size: 0.7rem;">Thông tin tài khoản ngân hàng (Số TK, Ngân hàng, Tên)</label>
                        <textarea name="bankInfo" class="lux-input w-100" rows="3" placeholder="VD: 12345678, Vietcombank, NGUYEN VAN A" required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="submit" class="lux-btn-primary w-100 py-3 mt-2">Xác nhận rút tiền <i class="bi bi-check-lg ms-2"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .shadow-xl { box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); }
    .display-5 { font-size: 3rem; letter-spacing: -1px; }
</style>
