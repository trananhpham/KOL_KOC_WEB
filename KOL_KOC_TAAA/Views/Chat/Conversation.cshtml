@model KOL_KOC_TAAA.Models.ChatConversation
@{
    ViewData["Title"] = "Hội thoại";
    Layout = "_LayoutDashboard";
    var otherMember = Model.ChatMembers.FirstOrDefault(m => m.UserId != (Guid)ViewBag.CurrentUserId)?.User;
    var messages = (List<KOL_KOC_TAAA.Models.ChatMessage>)ViewBag.Messages;
}

<div class="chat-container d-flex flex-column" style="height: calc(100vh - 160px);">
    <!-- Chat Header -->
    <div class="dash-card p-3 mb-3 d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-link text-dark p-0 d-lg-none me-2"><i class="bi bi-arrow-left fs-4"></i></a>
            <div class="avatar-circle rounded-circle bg-indigo-subtle d-flex align-items-center justify-content-center text-primary fw-bold" style="width: 40px; height: 40px;">
                 @if (!string.IsNullOrEmpty(otherMember?.AvatarUrl))
                {
                    <img src="@otherMember.AvatarUrl" class="w-100 h-100 rounded-circle" style="object-fit: cover;">
                }
                else
                {
                    @(otherMember?.FullName?[0..1] ?? "U")
                }
            </div>
            <div>
                <h6 class="fw-bold mb-0">@otherMember?.FullName</h6>
                @if (Model.Type == "booking_negotiation")
                {
                    <div class="small text-muted" style="font-size: 0.7rem;">Thương lượng: <strong class="text-primary">@Model.BookingRequest?.Title</strong></div>
                }
                else
                {
                    <div class="small text-success" style="font-size: 0.7rem;"><i class="bi bi-circle-fill me-1" style="font-size: 0.4rem;"></i> Đang trực tuyến</div>
                }
            </div>
        </div>
        <div class="d-flex gap-2">
             @if (Model.Type == "booking_negotiation" && Model.BookingRequest != null)
             {
                 <a href="#" class="btn btn-outline-primary btn-sm rounded-pill px-3">Xem Request</a>
             }
             <button class="btn btn-light btn-sm rounded-circle"><i class="bi bi-three-dots-vertical"></i></button>
        </div>
    </div>

    <!-- Message Area -->
    <div class="flex-grow-1 overflow-auto p-3 mb-3 bg-white rounded-4 shadow-sm border" id="message-flow">
        @foreach (var msg in messages)
        {
            var isMine = msg.SenderUserId == (Guid)ViewBag.CurrentUserId;
            var isSystem = msg.MessageType == "system";

            if (isSystem)
            {
                <div class="text-center my-4">
                    <span class="badge rounded-pill bg-light text-muted px-4 py-2 border shadow-sm" style="font-size: 0.75rem; font-weight: 500;">
                         @Html.Raw(msg.Content)
                    </span>
                </div>
            }
            else
            {
                <div class="d-flex @(isMine ? "justify-content-end" : "justify-content-start") mb-4">
                    <div class="message-bubble @(isMine ? "bg-indigo text-white ms-5" : "bg-light text-dark me-5") p-3 rounded-4 shadow-sm position-relative" style="max-width: 75%;">
                        <div class="small mb-1 @(isMine ? "text-white-50" : "text-muted")">@(isMine ? "Bạn" : msg.SenderUser?.FullName ?? "Đối tác")</div>
                        <div style="line-height: 1.5; word-wrap: break-word;">@msg.Content</div>
                        <div class="text-end mt-1" style="font-size: 0.6rem; opacity: 0.6;">@msg.SentAt.ToString("HH:mm")</div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Input Area -->
    <div class="dash-card p-2 bg-white rounded-5 shadow-lg border-0">
        <form id="chat-form" class="d-flex gap-2 align-items-center">
            <button type="button" class="btn btn-light rounded-circle" style="width: 42px; height: 42px;"><i class="bi bi-plus-lg"></i></button>
            <input id="chat-input" type="text" class="form-control border-0 bg-transparent py-2 shadow-none" placeholder="Nhập tin nhắn..." autocomplete="off">
            <button type="submit" class="btn btn-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                <i class="bi bi-send-fill" style="margin-left: 2px;"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const flow = document.getElementById('message-flow');
        flow.scrollTop = flow.scrollHeight;

        const chatForm = document.getElementById('chat-form');
        const chatInput = document.getElementById('chat-input');
        const currentUserId = '@ViewBag.CurrentUserId';

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const content = chatInput.value.trim();
            if (!content) return;

            const conversationId = '@Model.Id';
            
            try {
                const response = await fetch('/Chat/SendMessage', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `conversationId=${conversationId}&content=${encodeURIComponent(content)}`
                });

                if (response.ok) {
                    const data = await response.json();
                    appendMessage(data.message);
                    chatInput.value = '';
                    flow.scrollTop = flow.scrollHeight;
                }
            } catch (err) {
                console.error("Lỗi gửi tin nhắn:", err);
            }
        });

        function appendMessage(msg) {
            const isMine = msg.senderId === currentUserId;
            const msgHtml = `
                <div class="d-flex ${isMine ? 'justify-content-end' : 'justify-content-start'} mb-4">
                    <div class="message-bubble ${isMine ? 'bg-indigo text-white ms-5' : 'bg-light text-dark me-5'} p-3 rounded-4 shadow-sm position-relative" style="max-width: 75%;">
                        <div class="small mb-1 ${isMine ? 'text-white-50' : 'text-muted'}">${isMine ? 'Bạn' : 'Đối tác'}</div>
                        <div style="line-height: 1.5; word-wrap: break-word;">${msg.content}</div>
                        <div class="text-end mt-1" style="font-size: 0.6rem; opacity: 0.6;">${msg.sentAt}</div>
                    </div>
                </div>
            `;
            flow.insertAdjacentHTML('beforeend', msgHtml);
        }
    </script>
}

<style>
    .bg-indigo { background-color: var(--lux-primary-indigo); }
    .message-bubble { border: 1px solid rgba(0,0,0,0.03); }
    #message-flow::-webkit-scrollbar { width: 4px; }
    #message-flow::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
</style>
