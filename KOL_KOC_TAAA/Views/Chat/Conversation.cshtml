@model KOL_KOC_TAAA.Models.ChatConversation
@using System.Security.Claims
@{
    Layout = "_LayoutLuxury";
    ViewData["Title"] = $"Chat với {Model.ChatMembers.FirstOrDefault(m => m.UserId != Guid.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)))?.User?.FullName} - KOL Market";
    var currentUserId = Guid.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier));
    var messages = ViewBag.Messages as List<KOL_KOC_TAAA.Models.ChatMessage> ?? new List<KOL_KOC_TAAA.Models.ChatMessage>();
}

<div class="container-fluid py-4" style="height: calc(100vh - 100px);">
    <div class="row h-100 g-0 lux-surface overflow-hidden">
        <!-- Sidebar: Conversation List: Dẫn hướng nhanh (Hidden on mobile) -->
        <div class="col-lg-4 col-xl-3 border-end h-100 d-none d-lg-flex flex-column">
             <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
                <h2 class="lux-h2 mb-0">Hội thoại</h2>
                <a asp-action="Index" class="lux-btn-outline btn-sm">Tất cả</a>
            </div>
            <div class="flex-grow-1 overflow-auto bg-white">
                <div class="p-5 text-center text-muted opacity-50">
                    <p class="small">Danh sách rút gọn đang được cập nhật...</p>
                </div>
            </div>
        </div>

        <!-- Main Chat Area -->
        <div class="col-lg-8 col-xl-9 h-100 d-flex flex-column bg-white">
            <!-- Header -->
            <div class="p-3 border-bottom d-flex align-items-center justify-content-between bg-white position-relative z-1">
                <div class="d-flex align-items-center gap-3">
                    <a asp-action="Index" class="lux-link d-lg-none"><i class="bi bi-chevron-left fs-4"></i></a>
                    <div class="position-relative">
                        <img src="https://ui-avatars.com/api/?name=@(Model.ChatMembers.FirstOrDefault(m => m.UserId != currentUserId)?.User?.FullName ?? "User")&background=random" class="rounded-circle" width="45" height="45">
                        <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-white rounded-circle"></span>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">@(Model.ChatMembers.FirstOrDefault(m => m.UserId != currentUserId)?.User?.FullName ?? "Đối tác")</h6>
                        <span class="smaller text-muted text-uppercase ls-1">@Model.Type.Replace("_", " ")</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    @if (Model.Type == "booking_negotiation") {
                        <a asp-controller="Booking" asp-action="Index" class="lux-btn-primary btn-sm px-3">CHI TIẾT ĐƠN HÀNG</a>
                    }
                    <button class="lux-btn-outline btn-sm"><i class="bi bi-three-dots-vertical"></i></button>
                </div>
            </div>

            <!-- Messages Window -->
            <div id="chat-window" class="flex-grow-1 overflow-auto p-4 bg-light d-flex flex-column gap-3" style="background-image: radial-gradient(var(--lux-border) 1px, transparent 0); background-size: 20px 20px;">
                @foreach (var msg in messages.OrderBy(m => m.SentAt))
                {
                    var isMine = msg.SenderUserId == currentUserId;
                    <div class="message-wrapper d-flex @(isMine ? "justify-content-end" : "justify-content-start")" data-reveal="fade-up">
                        <div class="message-bubble @(isMine ? "mine" : "theirs") p-3">
                            <p class="mb-1">@msg.Content</p>
                            <span class="smaller opacity-50 d-block text-end">@msg.SentAt.ToString("HH:mm")</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Input Area -->
            <div class="p-3 border-top bg-white">
                <form id="chat-form" class="d-flex gap-3 align-items-end">
                    <input type="hidden" id="conversationId" value="@Model.Id" />
                    <div class="flex-grow-1 position-relative">
                        <textarea id="message-input" rows="1" class="lux-input w-100 py-3 pe-5" placeholder="Viết phản hồi của bạn..." style="border-radius: 20px; resize: none;"></textarea>
                        <button type="button" class="position-absolute end-0 top-50 translate-middle-y border-0 bg-transparent pe-3 text-muted"><i class="bi bi-paperclip"></i></button>
                    </div>
                    <button type="submit" class="lux-btn-primary rounded-circle d-flex align-items-center justify-content-center shadow-gold" style="width: 50px; height: 50px; flex-shrink: 0;"><i class="bi bi-send-fill text-white fs-5"></i></button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .message-bubble {
        max-width: 65%;
        border-radius: 20px;
        position: relative;
        font-size: 0.95rem;
    }
    .message-bubble.mine {
        background: linear-gradient(135deg, var(--lux-primary-indigo), #4f46e5);
        color: white;
        border-bottom-right-radius: 4px;
        box-shadow: 0 4px 15px rgba(79, 70, 229, 0.2);
    }
    .message-bubble.theirs {
        background-color: white;
        color: var(--lux-text-dark);
        border: 1px solid var(--lux-border);
        border-bottom-left-radius: 4px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    }
    .shadow-gold { box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3); }
    #chat-window { scroll-behavior: smooth; }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            const chatWindow = document.getElementById('chat-window');
            chatWindow.scrollTop = chatWindow.scrollHeight;

            $('#chat-form').on('submit', function(e) {
                e.preventDefault();
                const content = $('#message-input').val().trim();
                const convId = $('#conversationId').val();

                if (!content) return;

                $.post('/Chat/SendMessage', { conversationId: convId, content: content }, function(data) {
                    if (data.success) {
                        const html = `
                            <div class="message-wrapper d-flex justify-content-end mb-2">
                                <div class="message-bubble mine p-3">
                                    <p class="mb-1">${data.message.content}</p>
                                    <span class="smaller opacity-50 d-block text-end">${data.message.sentAt}</span>
                                </div>
                            </div>
                        `;
                        $('#chat-window').append(html);
                        $('#message-input').val('').trigger('input');
                        chatWindow.scrollTop = chatWindow.scrollHeight;
                    }
                });
            });

            // Auto-resize textarea
            const tx = document.getElementById('message-input');
            tx.addEventListener("input", OnInput, false);
            function OnInput() {
                this.style.height = 'auto';
                this.style.height = (this.scrollHeight) + 'px';
            }
        });
    </script>
}
