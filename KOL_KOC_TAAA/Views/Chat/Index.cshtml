@model IEnumerable<KOL_KOC_TAAA.ViewModels.ConversationViewModel>
@{
    ViewData["Title"] = "Tin nhắn";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h3 class="mb-4">Hội thoại của bạn</h3>
            
            <div class="list-group shadow-sm">
                @if (!Model.Any())
                {
                    <div class="list-group-item text-center py-5 text-muted">
                        <p class="mb-0">Bạn chưa có cuộc hội thoại nào.</p>
                    </div>
                }
                @foreach (var chat in Model)
                {
                    <a asp-action="Details" asp-route-id="@chat.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(chat.OtherUserName)&background=random&size=50" class="rounded-circle" alt="Avatar">
                            </div>
                            <div class="ms-3">
                                <h6 class="mb-0">@chat.OtherUserName</h6>
                                <p class="mb-0 text-muted small text-truncate" style="max-width: 400px;">@chat.LastMessage</p>
                            </div>
                        </div>
                        <div class="text-end">
                            <small class="text-muted d-block">@chat.LastMessageTime.ToLocalTime().ToString("dd/MM HH:mm")</small>
                            @if (chat.ConversationType == "booking")
                            {
                                <span class="badge bg-light text-primary border mt-1">Booking</span>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>
</div>
