@model IEnumerable<KOL_KOC_TAAA.Models.ChatConversation>
@{
    ViewData["Title"] = "Tin nhắn";
    Layout = "_LayoutDashboard";
}

<div class="mb-4">
    <h2 class="h4 fw-bold mb-1">Hộp thư tin nhắn</h2>
    <p class="text-muted small">Đàm phán và trao đổi trực tiếp với đối tác của bạn.</p>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="dash-card p-0 overflow-hidden">
            @if (Model != null && Model.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var conv in Model)
                    {
                        var otherMember = conv.ChatMembers.FirstOrDefault(m => m.UserId != Guid.Parse(User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier)))?.User;
                        var lastMessage = conv.ChatMessages.FirstOrDefault();
                        
                        <a asp-action="Conversation" asp-route-id="@conv.Id" class="list-group-item list-group-item-action p-4 border-0 border-bottom border-light">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-circle rounded-circle bg-light d-flex align-items-center justify-content-center fw-bold text-primary" style="width: 54px; height: 54px; font-size: 1.2rem; flex-shrink: 0;">
                                    @if (!string.IsNullOrEmpty(otherMember?.AvatarUrl))
                                    {
                                        <img src="@otherMember.AvatarUrl" class="w-100 h-100 rounded-circle" style="object-fit: cover;">
                                    }
                                    else
                                    {
                                        @(otherMember?.FullName?[0..1] ?? "U")
                                    }
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="fw-bold mb-0">@otherMember?.FullName</h6>
                                        <span class="small text-muted" style="font-size: 0.7rem;">@conv.UpdatedAt.ToString("dd/MM HH:mm")</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="text-muted small mb-0 text-truncate" style="max-width: 80%;">
                                            @if (lastMessage != null)
                                            {
                                                @(lastMessage.SenderUserId == Guid.Parse(User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier)) ? "Bạn: " : "")@lastMessage.Content
                                            }
                                            else
                                            {
                                                <span class="italic opacity-50">Bắt đầu cuộc hội thoại...</span>
                                            }
                                        </p>
                                        @if (conv.Type == "booking_negotiation")
                                        {
                                            <span class="badge rounded-pill bg-indigo-subtle text-primary" style="font-size: 0.6rem;">Booking</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-chat-square-dots fs-1 text-muted opacity-25 mb-3 d-block"></i>
                    <h5 class="fw-bold">Hộp thư đang trống</h5>
                    <p class="text-muted small">Mọi cuộc thảo luận về chiến dịch sẽ hiển thị ở đây.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .list-group-item-action:hover {
        background-color: #f8fafc !important;
    }
</style>
