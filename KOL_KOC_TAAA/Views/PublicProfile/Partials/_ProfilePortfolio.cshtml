@model List<KOL_KOC_TAAA.Models.KolPortfolio>

<div class="lux-portfolio py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold text-indigo mb-0">Dự án & Sản phẩm đã thực hiện</h5>
        <span class="badge bg-light text-dark rounded-pill px-3 py-2">@Model.Count items</span>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 border rounded-4 bg-light opacity-50">
            <i class="bi bi-images display-4 d-block mb-3"></i>
            <p>KOL chưa cập nhật Portfolio công khai.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-xl-4" data-reveal="fade-up">
                    <div class="portfolio-item-card overflow-hidden rounded-4 border bg-white h-100">
                        <div class="port-img-wrap position-relative" style="height: 200px;">
                            <img src="@item.MediaUrl" alt="@item.Title" class="w-100 h-100 object-fit-cover">
                            <div class="port-overlay d-flex align-items-center justify-content-center">
                                <button class="btn btn-white btn-sm rounded-pill px-3 shadow">Chi tiết</button>
                            </div>
                        </div>
                        <div class="p-3">
                            <h6 class="fw-bold mb-1 text-truncate">@item.Title</h6>
                            <p class="text-muted small mb-0 line-clamp-2">@item.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .portfolio-item-card {
        transition: all 0.3s var(--lux-ease);
    }
    .portfolio-item-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }
    .port-img-wrap .port-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.2);
        opacity: 0;
        transition: all 0.3s ease;
    }
    .portfolio-item-card:hover .port-overlay {
        opacity: 1;
    }
    .btn-white { background: #fff; border: none; font-weight: 600; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
