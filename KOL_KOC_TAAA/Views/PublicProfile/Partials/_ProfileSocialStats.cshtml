@model List<KOL_KOC_TAAA.Models.KolSocialAccount>

<div class="lux-social-stats py-4">
    <h5 class="fw-bold mb-4 text-indigo">Số liệu mạng xã hội</h5>
    <div class="row g-3">
        @foreach (var acc in Model)
        {
            <div class="col-md-6 col-xl-4" data-reveal="fade-up">
                <div class="social-stat-card p-3 border rounded-4 d-flex align-items-center gap-3 bg-white">
                    <div class="plat-icon @acc.Platform.ToLower()">
                        <i class="bi bi-@(acc.Platform.ToLower())"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold fs-5">@(acc.Followers?.ToString("N0") ?? "0")</span>
                            <span class="text-success small fw-bold">+@acc.EngagementRate%</span>
                        </div>
                        <div class="text-muted small">@acc.Platform | @acc.Username</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .plat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #fff;
    }
    .plat-icon.facebook { background: #1877F2; }
    .plat-icon.instagram { background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); }
    .plat-icon.tiktok { background: #000; }
    .plat-icon.youtube { background: #FF0000; }
    .plat-icon.twitter, .plat-icon.x { background: #1DA1F2; }
    
    .social-stat-card {
        transition: all 0.3s ease;
    }
    .social-stat-card:hover {
        border-color: var(--lux-accent-gold) !important;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }
</style>
