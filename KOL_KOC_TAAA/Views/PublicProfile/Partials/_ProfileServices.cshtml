@model List<KOL_KOC_TAAA.Models.RateCard>

<div class="lux-services py-4">
    <h5 class="fw-bold mb-4 text-indigo">Bảng giá dịch vụ</h5>
    
    @if (Model == null || !Model.Any() || !Model.Any(rc => rc.RateCardItems.Any()))
    {
        <div class="p-4 border rounded-4 bg-light text-center opacity-75">
            <i class="bi bi-tag display-6 d-block mb-3"></i>
            <p class="mb-0">KOL hiện chưa công khai bảng giá. Vui lòng nhắn tin để thương lượng.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var rc in Model)
            {
                foreach (var item in rc.RateCardItems)
                {
                    <div class="col-md-6" data-reveal="fade-up">
                        <div class="rate-card-item p-4 border rounded-4 bg-white shadow-sm position-relative overflow-hidden h-100">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h6 class="fw-bold mb-1">@rc.Title - @item.ServiceType</h6>
                                    <div class="badge bg-indigo-soft text-indigo small">Hệ: @item.Platform</div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold fs-5 text-gold">@item.UnitPrice.ToString("N0")đ</div>
                                </div>
                            </div>
                            <p class="text-muted small mb-0">@item.Description</p>
                            <!-- Subtle background icon -->
                            <div class="position-absolute bottom-0 end-0 opacity-05" style="font-size: 4rem; margin-right: -10px; margin-bottom: -15px;">
                                <i class="bi bi-tag"></i>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

<style>
    .rate-card-item {
        transition: all 0.3s ease;
        border-left: 4px solid var(--lux-accent-gold) !important;
    }
    .rate-card-item:hover {
        transform: scale(1.02);
        box-shadow: 0 12px 25px rgba(0,0,0,0.06);
    }
    .bg-indigo-soft { background: rgba(26, 28, 44, 0.05); }
    .opacity-05 { opacity: 0.05; }
</style>
