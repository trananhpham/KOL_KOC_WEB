@model IEnumerable<KOL_KOC_TAAA.Models.Booking>
@{
    ViewData["Title"] = "Thống kê hệ thống";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card admin-card p-3">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0 bg-primary-subtle p-3 rounded-3 text-primary">
                    <i class="bi bi-people-fill fs-3"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h6 class="text-muted small text-uppercase mb-1">Người dùng</h6>
                    <h4 class="mb-0 fw-bold">@ViewBag.TotalUsers</h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card admin-card p-3">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0 bg-success-subtle p-3 rounded-3 text-success">
                    <i class="bi bi-star-fill fs-3"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h6 class="text-muted small text-uppercase mb-1">KOLs Active</h6>
                    <h4 class="mb-0 fw-bold">@ViewBag.TotalKols</h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card admin-card p-3">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0 bg-warning-subtle p-3 rounded-3 text-warning">
                    <i class="bi bi-cart-check-fill fs-3"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h6 class="text-muted small text-uppercase mb-1">Tổng Bookings</h6>
                    <h4 class="mb-0 fw-bold">@ViewBag.TotalBookings</h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card admin-card p-3">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0 bg-danger-subtle p-3 rounded-3 text-danger">
                    <i class="bi bi-cash-coin fs-3"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h6 class="text-muted small text-uppercase mb-1">Doanh thu sàn</h6>
                    <h4 class="mb-0 fw-bold">@ViewBag.PlatformRevenue.ToString("N0") VND</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card admin-card">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold">Bookings mới nhất</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Khách hàng</th>
                        <th>KOL</th>
                        <th>Giá trị</th>
                        <th>Phí sàn</th>
                        <th>Trạng thái</th>
                        <th>Thời gian</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        <tr>
                            <td>@b.CustomerUser.FullName</td>
                            <td>@b.KolUser.User.FullName</td>
                            <td class="fw-bold">@b.TotalAmount.ToString("N0")</td>
                            <td class="text-primary small">@b.PlatformFee.ToString("N0")</td>
                            <td>
                                <span class="badge rounded-pill @(b.Status == "Completed" ? "bg-success" : "bg-info text-dark")">@b.Status</span>
                            </td>
                            <td class="small text-muted">@b.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
