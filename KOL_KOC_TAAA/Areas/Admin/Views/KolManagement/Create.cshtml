@model KOL_KOC_TAAA.Areas.Admin.ViewModels.KolCreateViewModel
@{
    ViewData["Title"] = "Thêm mới KOL";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h3 class="fw-bold mb-1">Thêm mới KOL</h3>
        <p class="text-muted small mb-0">Tạo hồ sơ KOL/KOC mới cho hệ thống</p>
    </div>
    <a asp-action="Index" class="btn btn-light rounded-pill px-4 shadow-sm"><i class="bi bi-arrow-left me-2"></i>Quay lại</a>
</div>

<div class="glass-card-admin border-0 p-4">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <div class="col-md-6">
                <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-person-badge me-2"></i>Thông tin Tải khoản</h6>
                
                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold">Email Đăng nhập *</label>
                    <input asp-for="Email" class="form-control form-control-lg bg-light border-0" placeholder="nguyenvana@gmail.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold">Mật khẩu *</label>
                    <input asp-for="Password" type="password" class="form-control form-control-lg bg-light border-0" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold">Họ và Tên *</label>
                    <input asp-for="FullName" class="form-control form-control-lg bg-light border-0" placeholder="Nguyễn Văn A" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control form-control-lg bg-light border-0" placeholder="0901234567" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
            </div>

            <div class="col-md-6">
                <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-star me-2"></i>Thông tin Hồ sơ KOL</h6>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold">Phân loại Influencer *</label>
                    <select asp-for="InfluencerType" class="form-select form-select-lg bg-light border-0">
                        <option value="Nano">Nano (1k - 10k followers)</option>
                        <option value="Micro">Micro (10k - 100k followers)</option>
                        <option value="Macro">Macro (100k - 1M followers)</option>
                        <option value="Mega">Mega (>1M followers)</option>
                    </select>
                    <span asp-validation-for="InfluencerType" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold">Khu vực (Thành phố)</label>
                    <input asp-for="LocationCity" class="form-control form-control-lg bg-light border-0" placeholder="Hà Nội, TP.HCM..." />
                    <span asp-validation-for="LocationCity" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold">Quốc gia</label>
                    <input asp-for="LocationCountry" class="form-control form-control-lg bg-light border-0" value="Vietnam" />
                    <span asp-validation-for="LocationCountry" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold">Ngân sách Tối thiểu (VNĐ)</label>
                    <input asp-for="MinBudget" type="number" class="form-control form-control-lg bg-light border-0" placeholder="1000000" />
                    <span asp-validation-for="MinBudget" class="text-danger small"></span>
                </div>
            </div>
            
            <div class="col-12">
                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold">Tiểu sử (Bio)</label>
                    <textarea asp-for="Bio" class="form-control bg-light border-0" rows="4" placeholder="Giới thiệu về KOL..."></textarea>
                    <span asp-validation-for="Bio" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-primary btn-pill px-5 shadow-premium"><i class="bi bi-save me-2"></i>Tạo KOL Mới</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
