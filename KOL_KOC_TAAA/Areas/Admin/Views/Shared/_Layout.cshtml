<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; }
        .sidebar { min-height: 100vh; background-color: #212529; color: white; }
        .sidebar .nav-link { color: #adb5bd; border-radius: 5px; margin-bottom: 5px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: #343a40; color: white; }
        .admin-card { border: none; border-radius: 10px; box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075); }
        .main-content { padding: 2rem; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 sidebar d-md-block p-4 collapse">
                <div class="mb-4">
                    <h5 class="fw-bold text-warning"><i class="bi bi-shield-lock-fill"></i> KOL ADMIN</h5>
                </div>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link active" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "KolManagement" ? "active" : "")" asp-area="Admin" asp-controller="KolManagement" asp-action="Index">
                            <i class="bi bi-patch-check me-2"></i> Duyệt KOL
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Payouts" ? "active" : "")" asp-area="Admin" asp-controller="Finances" asp-action="Payouts">
                            <i class="bi bi-wallet2 me-2"></i> Payout Requests
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="bi bi-exclamation-triangle me-2"></i> Khiếu nại
                        </a>
                    </li>
                    <li class="nav-item mt-4">
                        <a class="nav-link text-danger" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-arrow-left-circle me-2"></i> Về Client App
                        </a>
                    </li>
                </ul>
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 p-0">
                <nav class="navbar navbar-expand-lg navbar-white bg-white border-bottom p-3">
                    <div class="container-fluid">
                        <span class="navbar-text">Hệ thống quản trị Marketplace</span>
                        <div class="ms-auto d-flex align-items-center">
                            <span class="me-3 small text-muted">Admin: @User.Identity?.Name</span>
                            <a asp-area="" asp-controller="Auth" asp-action="Logout" class="btn btn-sm btn-outline-danger">Đăng thoát</a>
                        </div>
                    </div>
                </nav>

                <div class="main-content">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
